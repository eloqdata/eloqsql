include/mono_init.inc
DROP TABLE IF EXISTS t1;
CREATE TABLE t1 (pk int primary key, sk int) ENGINE=eloq;
INSERT INTO t1 VALUES (1, 1),(2, 2);
SELECT * FROM t1;
pk	sk
1	1
2	2
connection serv_2;
SET SESSION debug_dbug="+d,eloq;init_tx_error;node_id=1";
INSERT INTO t1 VALUES(1, 0);
ERROR HY000: Eloq: failed to start transaction at eloq engine, Txservice is not ready yet.
connection serv_1;
SET SESSION debug_dbug="-d,eloq;init_tx_error;node_id=1";
SELECT * FROM t1;
pk	sk
1	1
2	2
DROP TABLE t1;
