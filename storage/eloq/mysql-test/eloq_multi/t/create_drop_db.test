--source include/have_eloq.inc
set @@default_storage_engine=eloq;

--let $mono_server_count=3
--source include/mono_init.inc

--disable_warnings
DROP DATABASE IF EXISTS db1;
DROP DATABASE IF EXISTS db2;
--enable_warnings

# Connect to serv1: Create two databases, db1 and db2
--connection serv_1
CREATE DATABASE db1;
CREATE DATABASE db2;

# Connect to serv_2: List all databases and drop db2
--connection serv_2
SHOW DATABASES;
DROP DATABASE db2;

# Connect to serv_3: List all databases and create table t1 in db1;
--connection serv_3
SHOW DATABASES;
USE db1; 
CREATE TABLE t1 (i int primary key, j int) engine=eloq;

# Connect to serv_2: List all tables in db1 and drop table t1
--connection serv_2
USE db1;
SHOW TABLES;
DROP TABLE t1;

# Connect to serv_1: List all tables in db1 and drop db1
USE db1;
SHOW TABLES;
DROP DATABASE db1;
