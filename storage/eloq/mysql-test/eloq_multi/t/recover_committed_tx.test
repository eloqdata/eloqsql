#This case is to simulate the situation of recovering committed txn's orphan lock.
--source include/have_eloq.inc

--let $mono_server_count=3
--source include/mono_init.inc
--sleep 8

--disable_warnings
DROP TABLE IF EXISTS t1;
--enable_warnings

--connection serv_1
create table t1(i int primary key, j int) engine=eloq;

insert into t1 values(1,1);
insert into t1 values(2,2);
insert into t1 values(3,3);
insert into t1 values(4,4);
insert into t1 values(5,5);
select * from t1;

SET SESSION debug_dbug="+d,eloq;checkpointer_skip_ckpt;node_id=-1";
SET SESSION debug_dbug="+d,eloq;after_write_log;node_id=0;action=panic";

# Run the crashing query
--error 2013
update t1 set j = 0 where i > 0;

--exec echo "restart" > $MYSQLTEST_VARDIR/tmp/mysqld.1.expect

--enable_reconnect
--source include/wait_until_connected_again.inc


--connection serv_2
# first txn detecting lock conflicts will abort under OCC
# Under OCC protocol, return error(199);
# Under OccRead or Locking protocol, read will block until acquired WriteIntent lock. 
# So, the query is executed successfully.

let $counter= 60;
let $mysql_errno= 9999;
--disable_result_log
--disable_query_log
while ($mysql_errno)
{
  --error 0,213 
  update t1 set j = 10 where i > 0;

  dec $counter;
  if (!$counter)
  {
    --die recover failed
  }
  if ($mysql_errno > 0)
  {
    # the above txn triggers CheckRecoverTx, wait for the result from log service
    --sleep 0.5
  }
}
--enable_query_log
--enable_result_log

# the above txn triggers CheckRecoverTx, wait for the result from log service
--sleep 2
update t1 set j = 1 where i > 0;
select * from t1;

drop table t1;

SET SESSION debug_dbug="-d,eloq;after_write_log";
SET SESSION debug_dbug="-d,eloq;checkpointer_skip_ckpt;node_id=-1";