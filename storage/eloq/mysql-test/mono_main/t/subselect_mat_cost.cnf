
# Use default setting for mysqld processes
!include include/default_mysqld.cnf
!include include/default_client.cnf

!include include/eloq_kv_keyspace.cnf


[mysqld]
plugin-maturity=experimental
skip-log-bin
default-storage-engine=eloq
default-tmp-storage-engine=eloq
collation-server=latin1_bin
eloq_cc_protocol=OCC
use_stat_tables=complementary
eloq_config = @ENV.MYSQLTEST_VARDIR/../../../storage/eloq/mysql-test/mono_main/data_substrate.cnf

[mysqld.1]

[ENV]
MONO1_PORT=              @mysqld.1.port
MONO1_SOCK=              @mysqld.1.socket

[mysqldump]
# LOCK/UNLOCK TABLES no support for ELOQ
skip-lock-tables
skip-add-locks
# ALTER TABLE no support for ELOQ
skip-disable-keys