include/mono_init.inc
DROP DATABASE IF EXISTS mono_test;
set @@default_storage_engine= eloq;
connection serv_1;
CREATE DATABASE IF NOT EXISTS mono_test;
USE mono_test;
#***************************************************************
#             Test CREATE INDEX
#***************************************************************
#
# Test 1 add index operation.
#
create table t3 (c0 int primary key, c1 char(200), c2 varchar(200), c3 text, c4 int);
Insert data...
select count(*) from t3;
count(*)
10000
create index idx_c1 on t3 (c1);
create index idx_c2 on t3 (c2);
create index idx_c3 on t3 (c3(10));
show create table t3;
Table	Create Table
t3	CREATE TABLE `t3` (
  `c0` int(11) NOT NULL,
  `c1` char(200) DEFAULT NULL,
  `c2` varchar(200) DEFAULT NULL,
  `c3` text DEFAULT NULL,
  `c4` int(11) DEFAULT NULL,
  PRIMARY KEY (`c0`),
  KEY `idx_c1` (`c1`),
  KEY `idx_c2` (`c2`),
  KEY `idx_c3` (`c3`(10))
) ENGINE=ELOQ DEFAULT CHARSET=latin1
