set @@default_storage_engine=eloq;
include/mono_init.inc
connection serv_1;
CREATE TEMPORARY TABLE t1 (
i INT PRIMARY KEY,
dt DATETIME(3) DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP
);
INSERT INTO t1 (i) values(10001), (10002), (10003), (10004), (10005);
