include/mono_init.inc
DROP TABLE IF EXISTS t1;
connection serv_1;
set session transaction isolation level read committed;
select @@tx_isolation;
@@tx_isolation
READ-COMMITTED
CREATE TABLE t1 (pk INT , sk INT, col INT, PRIMARY KEY (pk), INDEX sk (sk)) ENGINE=eloq;
INSERT INTO t1 VALUES (1,10,100),(2,20,200);
select * from t1;
pk	sk	col
1	10	100
2	20	200
SET SESSION debug_dbug="+d,eloq;delay_release_write_lock_on_pk;node_id=-1";
update t1 set sk=40 where pk=2;;
log: finish send
connection serv_2;
set session transaction isolation level read committed;
select @@tx_isolation;
@@tx_isolation
READ-COMMITTED
log: send select and begin to sleep, should not read anything in 10 seconds
select * from t1 where sk=40;;
log: finish sleep and about to erase debug point, should not read anything during sleep period
connection serv_3;
SET SESSION debug_dbug="-d,eloq;delay_release_write_lock_on_pk";
connection serv_1;
select * from t1;
pk	sk	col
1	10	100
2	40	200
log: update successfully
connection serv_2;
log: expect to return (2,40,200) from previous read
pk	sk	col
2	40	200
drop table t1;
