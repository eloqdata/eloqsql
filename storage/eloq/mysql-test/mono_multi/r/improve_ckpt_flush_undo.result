include/mono_init.inc
DROP TABLE IF EXISTS t1;
connection serv_1;
create table t1(i int primary key, j int) engine= eloq;
SET SESSION debug_dbug="+d,eloq;stop_safely_clean_archives;node_id=-1";
insert into t1 values(1,1);
insert into t1 values(2,1);
insert into t1 values(3,1);
insert into t1 values(4,1);
insert into t1 values(5,1);
insert into t1 values(6,1);
insert into t1 values(7,1);
insert into t1 values(8,1);
select * from t1;
i	j
1	1
2	1
3	1
4	1
5	1
6	1
7	1
8	1
update t1 set j=2;
update t1 set j=3;
SET SESSION debug_dbug="+d,eloq;at_once;node_id=-1;action=NOTIFY_CHECKPOINTER";
explain select * from t1;
id	select_type	table	type	possible_keys	key	key_len	ref	rows	Extra
1	SIMPLE	t1	ALL	NULL	NULL	NULL	NULL	#	
begin;
## RESTULT MUST BE:  1,3 | 2,3 | ...
select * from t1;
i	j
1	3
2	3
3	3
4	3
5	3
6	3
7	3
8	3
##restart to clean ccmap
connection serv_2;
# restart
connection serv_3;
# restart
connection serv_1;
SET SESSION debug_dbug="+d,eloq;stop_safely_clean_archives;node_id=-1";
## RESTULT MUST BE:  1,3 | 2,3 | ...
select * from t1;
i	j
1	3
2	3
3	3
4	3
5	3
6	3
7	3
8	3
SET SESSION debug_dbug="+d,eloq;checkpointer_skip_ckpt;node_id=-1";
connection serv_2;
update t1 set j=4;
update t1 set j=5;
## RESTULT MUST BE:  1,5 | 2,5 | ...
select * from t1;
i	j
1	5
2	5
3	5
4	5
5	5
6	5
7	5
8	5
connection serv_1;
## RESTULT MUST BE:  1,3 | 2,3 | ...
select * from t1;
i	j
1	3
2	3
3	3
4	3
5	3
6	3
7	3
8	3
##restart to triger RedoLogReplay
connection serv_2;
# restart
## RESTULT MUST BE:  1,5 | 2,5 | ...
select * from t1;
i	j
1	5
2	5
3	5
4	5
5	5
6	5
7	5
8	5
connection serv_3;
# restart
## RESTULT MUST BE:  1,5 | 2,5 | ...
select * from t1;
i	j
1	5
2	5
3	5
4	5
5	5
6	5
7	5
8	5
connection serv_1;
SET SESSION debug_dbug="-d,eloq;checkpointer_skip_ckpt;node_id=-1";
SET SESSION debug_dbug="+d,eloq;at_once;node_id=-1;action=NOTIFY_CHECKPOINTER";
## RESTULT MUST BE:  1,3 | 2,3 | ...
select * from t1;
i	j
1	3
2	3
3	3
4	3
5	3
6	3
7	3
8	3
select * from t1 where i=2;
i	j
2	3
select * from t1 where i=6;
i	j
6	3
commit;
## RESTULT MUST BE:  1,5 | 2,5 | ...
select * from t1;
i	j
1	5
2	5
3	5
4	5
5	5
6	5
7	5
8	5
drop table t1;
