--source include/have_eloq.inc
--let $mono_server_count= 3
--source include/mono_init.inc
--sleep 3 #Here is bug, If not sleep, the mysqld will not return result.

--disable_warnings
DROP TABLE IF EXISTS t1;
--enable_warnings


#### test the change of flushing undo:
#### changes: fetching base table from kvstore if necessary, instead of always
#### flushing latest version to archives when do checkpoint.

# Connect to serv_1: Create table t1;
--connection serv_1

create table t1(i int primary key, j int, k int , index(j)) engine= eloq;

SET SESSION debug_dbug="+d,eloq;stop_safely_clean_archives;node_id=-1";

insert into t1 values(1,1,1);
insert into t1 values(2,2,2);
insert into t1 values(3,3,3);
insert into t1 values(4,4,4);
insert into t1 values(5,5,5);
insert into t1 values(6,6,6);
insert into t1 values(7,7,7);
insert into t1 values(8,8,8);
insert into t1 values(9,9,9);
insert into t1 values(10,10,10);
insert into t1 values(11,11,11);
insert into t1 values(12,12,12);
insert into t1 values(13,13,13);
insert into t1 values(14,14,14);
insert into t1 values(15,15,15);
insert into t1 values(16,16,16);

select * from t1;
update t1 set j=2;
update t1 set j=3;
delete from t1 where i=10;
delete from t1 where i=11;

SET SESSION debug_dbug="+d,eloq;at_once;node_id=-1;action=NOTIFY_CHECKPOINTER";
--sleep 2

--replace_column 9 #
explain select * from t1;

--replace_column 9 #
explain select * from t1 force index(j) where j>0;

begin;
--echo ## RESTULT MUST BE:  1,3,1 | 2,3,2 | ...
select * from t1;
select * from t1 force index(j) where j>0;    # 1,3,1 | 2,3,2 | ...

--echo ##restart to clean ccmap
--connection serv_2
--source include/restart_mysqld.inc
--connection serv_3
--source include/restart_mysqld.inc

--connection serv_3
begin;
--echo ## RESTULT MUST BE:  1,3,1 | 2,3,2 | ...
select * from t1;
select * from t1 force index(j) where j>0;    # 1,3,1 | 2,3,2 | ...

--connection serv_1
SET SESSION debug_dbug="+d,eloq;stop_safely_clean_archives;node_id=-1";

--echo ## RESTULT MUST BE:  # 1,3,1 | 2,3,2 | ...
select * from t1 force index(j) where j>0;    # 1,3,1 | 2,3,2 | ...

SET SESSION debug_dbug="+d,eloq;checkpointer_skip_ckpt;node_id=-1";
--sleep 1

--connection serv_2
update t1 set j=4;
update t1 set j=5;
--echo ## RESTULT MUST BE:   # 1,5,1 | 2,5,2 | ...
select * from t1 force index(j) where j>0;

--connection serv_1
--echo ## RESTULT MUST BE:  # 1,3,1 | 2,3,2 | ...
select * from t1 force index(j) where j>0;   # 1,3,1 | 2,3,2 | ...

--connection serv_3
--echo ## RESTULT MUST BE:  # 1,3,1 | 2,3,2 | ...
select * from t1 force index(j) where j>0;   # 1,3,1 | 2,3,2 | ...

--echo ##restart serv_2 to triger RedoLogReplay
--connection serv_2
--source include/restart_mysqld.inc
--echo ## RESTULT MUST BE:  1,5,1 | 2,5,2 | ...
select * from t1 force index(j) where j>0;

--connection serv_1
--echo ## RESTULT MUST BE:  # 1,3,1 | 2,3,2 | ...
select * from t1 force index(j) where j>0;   # 1,3,1 | 2,3,2 | ...
SET SESSION debug_dbug="-d,eloq;checkpointer_skip_ckpt;node_id=-1";
SET SESSION debug_dbug="+d,eloq;at_once;node_id=-1;action=NOTIFY_CHECKPOINTER";
# wait for ckpt finish
--sleep 1
--echo ## RESTULT MUST BE:  # 1,3,1 | 2,3,2 | ...
select * from t1;   # 1,3,1 | 2,3,2 | ...
select * from t1 force index(j) where j>0;   # 1,3,1 | 2,3,2 | ...
select * from t1 where i=2;
select * from t1 where i=6;
commit;

# Restart serv_1 to check whether the last ckpt version(j=3) is moved to archive
# before it is overwrited by ckpt version(j=5).
--connection serv_1
--source include/restart_mysqld.inc
--echo ## RESTULT MUST BE:  1,5,1 | 2,5,2 | ...
select * from t1 force index(j) where j>0;

--connection serv_3
--echo ## RESTULT MUST BE:  # 1,3,1 | 2,3,2 | ...
select * from t1 force index(j) where j>0;   # 1,3,1 | 2,3,2 | ...

--connection serv_2
begin;
--echo ## RESTULT MUST BE:  1,5,1 | 2,5,2 | ...
select * from t1 force index(j) where j>0;

--connection serv_1
SET SESSION debug_dbug="+d,eloq;checkpointer_skip_ckpt;node_id=-1";
update t1 set j=6;
# Restart serv_1 to check whether deleted sk ccentry's payload(unpack_info)
# can be recoverd from redo log (that is different with pk).
--source include/restart_mysqld.inc
--echo ## RESTULT MUST BE:  1,6,1 | 2,6,2 | ...
select * from t1 force index(j) where j>0;

--connection serv_2
--echo ## RESTULT MUST BE:  1,5,1 | 2,5,2 | ...
select * from t1 force index(j) where j>0;
commit;

--connection serv_3
--echo ## RESTULT MUST BE:  # 1,3,1 | 2,3,2 | ...
select * from t1 force index(j) where j>0;   # 1,3,1 | 2,3,2 | ...
commit;

--echo ## RESTULT MUST BE:  1,6,2 | 2,6,2 | ...
select * from t1;
select * from t1 force index(j) where j>0;

drop table t1;
