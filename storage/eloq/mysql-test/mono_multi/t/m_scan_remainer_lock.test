--source include/have_eloq.inc
set @@default_storage_engine= eloq;
--sleep 1 #Here is bug, If not sleep, the mysqld will not return result.

--let $mono_server_count= 3
--source include/mono_init.inc

--disable_warnings
DROP TABLE IF EXISTS t1;
--enable_warnings

create table t1(i int primary key auto_increment, j int)engine=eloq;
--let $count = 1
while ($count < 200)
{
    insert into t1 values(null, 1);
    --inc $count
}
select * from t1;

#To test when scan a table, the locks of remainder records will be release
# and do not affect other transcations.
--connection serv_1
begin;
update t1 set j=2 where i<=100;

--connection serv_2
begin;
update t1 set j=3 where i>100;
commit;

--connection serv_1
commit;
select * from t1;
drop table t1;