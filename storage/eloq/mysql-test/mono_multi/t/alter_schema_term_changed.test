--source include/have_eloq.inc
--source include/have_range_partition.inc
set @@default_storage_engine=eloq;

--let $mono_server_count=3
--source include/mono_init.inc

--disable_warnings
DROP TABLE IF EXISTS t1;
--enable_warnings

SET SESSION debug_dbug="+d,eloq;alter_schema_term_changed;node_id=0";
create table t1(i int primary key, j int) engine= eloq;
show tables;

create index idx_j on t1 (j);
show tables;

drop table t1;
SET SESSION debug_dbug="-d,eloq;alter_schema_term_changed";
