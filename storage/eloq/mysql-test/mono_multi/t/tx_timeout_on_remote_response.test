#test
--source include/have_eloq.inc
--let $mono_server_count= 3
--source include/mono_init.inc
--sleep 3 #Here is bug, If not sleep, the mysqld will not return result.

--disable_warnings
DROP TABLE IF EXISTS t2;
--enable_warnings

--connection serv_1
CREATE TABLE t2 (pk int primary key, sk int) ENGINE=eloq;
INSERT INTO t2 VALUES (1, 1),(2, 2),(3,3);

SET SESSION debug_dbug="+d,eloq;before_mark_remote_received;node_id=0";
# Transaction failed due to internal request timeout.
--error HA_ERR_LOCK_WAIT_TIMEOUT
SELECT * FROM t2;

SET SESSION debug_dbug="-d,eloq;before_mark_remote_received";

# wait for the interrupted remote receiving to finish
--sleep 10


DROP TABLE t2;
