--source include/have_eloq.inc
--sleep 2 #Here is bug, If not sleep, the mysqld will not return result.

--let $mono_server_count= 3
--source include/mono_init.inc
--disable_warnings
DROP TABLE IF EXISTS t1;
--enable_warnings

set @@default_storage_engine= eloq;
create table t1 (c0 int, c1 char(250), c2 char(250), c3 char(250), c4 int, primary key(c0));

let $counter= 6000;
--disable_result_log
--disable_query_log
while($counter > 3000)
{
    let $q=insert into t1 values ($counter, 'abc', 'abc', 'abc', $counter);
    eval $q;
    dec $counter;
}
--enable_query_log
--enable_result_log
SET SESSION debug_dbug="+d,eloq;at_once;node_id=-1;action=NOTIFY_CHECKPOINTER";
--sleep 2
select count(*) from t1;


let $counter= 3000;
--disable_result_log
--disable_query_log
while($counter > 0)
{
    let $q=insert into t1 values ($counter, 'abc', 'abc', 'abc', $counter);
    eval $q;
    dec $counter;
}
--enable_query_log
--enable_result_log
SET SESSION debug_dbug="+d,eloq;at_once;node_id=-1;action=NOTIFY_CHECKPOINTER";
--sleep 2
select count(*) from t1;



let $counter= 12000;
--disable_result_log
--disable_query_log
while($counter > 9000)
{
    let $q=insert into t1 values ($counter, 'abc', 'abc', 'abc', $counter);
    eval $q;
    dec $counter;
}
--enable_query_log
--enable_result_log
SET SESSION debug_dbug="+d,eloq;at_once;node_id=-1;action=NOTIFY_CHECKPOINTER";
--sleep 2
select count(*) from t1;

let $counter= 9000;
--disable_result_log
--disable_query_log
while($counter > 6000)
{
    let $q=insert into t1 values ($counter, 'abc', 'abc', 'abc', $counter);
    eval $q;
    dec $counter;
}
--enable_query_log
--enable_result_log
SET SESSION debug_dbug="+d,eloq;at_once;node_id=-1;action=NOTIFY_CHECKPOINTER";
--sleep 2
select count(*) from t1;
drop table t1;
