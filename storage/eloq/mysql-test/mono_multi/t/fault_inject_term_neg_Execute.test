# This case is to test what will happen if remote node 1 crash before it acquire and send message.

--source include/have_eloq.inc
--source include/long_test.inc
--sleep 8 #Here is bug, If not sleep, the mysqld will not return result.

--let $mono_server_count= 3
--source include/mono_init.inc

--connection serv_2
--disable_warnings
DROP TABLE IF EXISTS t1;
call mtr.add_suppression("Got error 127 when reading table './test/t1'");
call mtr.add_suppression("mariadbd: Table 't1' is marked as crashed and should be repaired");
--enable_warnings

#To skip ckpt in CheckPointer.cpp to avoid to release lock
SET SESSION debug_dbug="+d,eloq;checkpointer_skip_ckpt;node_id=-1";
#To skip sync table statistics in local_cc_shards.cpp to avoid to release lock
SET SESSION debug_dbug="+d,eloq;skip_sync_table_statistics;node_id=-1";

#Test in CatalogCcMap.Execute term return -1 one time, it will not affect create table
SET SESSION debug_dbug="+d,eloq;term_CatalogCcMap_Execute_PostWriteAllCc;node_id=-1";
create table t1(i int primary key, j int) engine= eloq;
insert into t1 values(1,1);
select * from t1;
drop table t1;

SET SESSION debug_dbug="+d,eloq;term_CatalogCcMap_Execute_ReadCc;node_id=-1";
create table t1(i int primary key, j int) engine= eloq;
insert into t1 values(1,1);
select * from t1;

SET SESSION debug_dbug="+d,eloq;term_TemplateCcMap_Execute_AcquireCc;node_id=-1";
--error 199
insert into t1 values(2,2);
select * from t1;

SET SESSION debug_dbug="-d,eloq;term_TemplateCcMap_Execute_AcquireCc";
insert into t1 values(2,3);
select * from t1;
drop table t1;

create table t1(i int primary key, j int) engine= eloq;
insert into t1 values(2,1);

SET SESSION debug_dbug="+d,eloq;term_TemplateCcMap_Execute_PostWriteCc;node_id=0#2";
insert into t1 values(1,1);
update t1 set j=2 where i=2;
insert into t1 values(3,1);

# readcc will recover the orphan lock
--sleep 9
# Case cc protocol is OCC or OccRead, readcc acquire ReadIntent,
# that is, readcc operation will not be blocked enen if write lock exists.
# But, the validation operation abort when committing tx.
# Case cc protocol is OCC or OccRead, readcc acquire ReadLock,
# that is, readcc operation will be blocked until WriteLock being released.
# So, the select query will be executed successfully.
--disable_result_log
let $cc_protocol = `select @@eloq_cc_protocol`;
if ($cc_protocol != 'Locking')
{
    --error 199
    select * from t1;
}
if ($cc_protocol == 'Locking')
{
    select * from t1;
}
--enable_result_log

--sleep 5
select * from t1;
drop table t1;
SET SESSION debug_dbug="-d,eloq;term_TemplateCcMap_Execute_PostWriteCc";


SET SESSION debug_dbug="+d,eloq;term_TemplateCcMap_Execute_AcquireAllCc;node_id=-1";
--error 200
create table t1(i int primary key, j int) engine= eloq;

SET SESSION debug_dbug="-d,eloq;term_TemplateCcMap_Execute_AcquireAllCc;node_id=-1";
create table t1(i int primary key, j int) engine= eloq;


SET SESSION debug_dbug="+d,eloq;term_TemplateCcMap_Execute_AcquireAllCc;node_id=-1";
--error ER_GET_ERRMSG
drop table t1;

SET SESSION debug_dbug="-d,eloq;term_TemplateCcMap_Execute_AcquireAllCc;node_id=-1";
drop table t1;


create table t1(i int primary key, j int) engine= eloq;
insert into t1 values(1,1);
insert into t1 values(2,2);
select * from t1;

SET SESSION debug_dbug="+d,eloq;term_TemplateCcMap_Execute_ReadCc;node_id=-1";
--error 216
select * from t1 where i=1;

SET SESSION debug_dbug="-d,eloq;term_TemplateCcMap_Execute_ReadCc;node_id=-1";
--sleep 6
update t1 set j=3 where i=2;
select * from t1 where i=2;
drop table t1;


create table t1(i int primary key, j int) engine= eloq;
insert into t1 values(1,1);
insert into t1 values(2,2);
insert into t1 values(3,3);
select * from t1;

SET SESSION debug_dbug="+d,eloq;term_TemplateCcMap_Execute_PostReadCc;node_id=0#2";
--error 199
select * from t1;

SET SESSION debug_dbug="-d,eloq;term_TemplateCcMap_Execute_PostReadCc;node_id=0#2";
--sleep 6
select * from t1;
drop table t1;


create table t1(i int primary key, j int) engine= eloq;
insert into t1 values(1,1);
insert into t1 values(2,2);
insert into t1 values(3,3);
select * from t1;

SET SESSION debug_dbug="+d,eloq;term_TemplateCcMap_Execute_ScanOpenBatchCc;node_id=-1";
select * from t1;

SET SESSION debug_dbug="-d,eloq;term_TemplateCcMap_Execute_ScanOpenBatchCc;node_id=-1";
select * from t1;

SET SESSION debug_dbug="+d,eloq;term_TemplateCcMap_Execute_RemoteScanOpen;node_id=-1";
select * from t1;

SET SESSION debug_dbug="-d,eloq;term_TemplateCcMap_Execute_RemoteScanOpen;node_id=-1";
select * from t1;
drop table t1;

SET SESSION debug_dbug="-d,eloq;checkpointer_skip_ckpt;node_id=-1";
SET SESSION debug_dbug="-d,eloq;skip_sync_table_statistics;node_id=-1";

create table t1(i int primary key, j int) engine= eloq;
SET SESSION debug_dbug="+d,eloq;term_TemplateCcMap_Execute_PostWriteCc;node_id=0#2";
insert into t1 values(1,1);
insert into t1 values(2,1);
insert into t1 values(3,1);

# wait for the checkpointer recover the orphan lock
--sleep 20
select * from t1;
drop table t1;
SET SESSION debug_dbug="-d,eloq;term_TemplateCcMap_Execute_PostWriteCc";
