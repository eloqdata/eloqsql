##
## Test NO PAD collation
##
set names utf8;
create table tvarcharnopad (id int, info varchar(16) collate utf8_nopad_bin) character set utf8;
show create table tvarcharnopad;
Table	Create Table
tvarcharnopad	CREATE TABLE `tvarcharnopad` (
  `id` int(11) DEFAULT NULL,
  `info` varchar(16) CHARACTER SET utf8mb3 COLLATE utf8mb3_nopad_bin DEFAULT NULL
) ENGINE=ELOQ DEFAULT CHARSET=utf8mb3
create table tvarchar (id int, info varchar(16) collate utf8_bin) character set utf8;
show create table tvarchar;
Table	Create Table
tvarchar	CREATE TABLE `tvarchar` (
  `id` int(11) DEFAULT NULL,
  `info` varchar(16) DEFAULT NULL
) ENGINE=ELOQ DEFAULT CHARSET=utf8mb3
create table tmediumtextnopad (id int, info mediumtext collate utf8_nopad_bin) character set utf8;
show create table tmediumtextnopad;
Table	Create Table
tmediumtextnopad	CREATE TABLE `tmediumtextnopad` (
  `id` int(11) DEFAULT NULL,
  `info` mediumtext CHARACTER SET utf8mb3 COLLATE utf8mb3_nopad_bin DEFAULT NULL
) ENGINE=ELOQ DEFAULT CHARSET=utf8mb3
create table tmediumtext (id int, info mediumtext collate utf8_bin) character set utf8;
show create table tmediumtext;
Table	Create Table
tmediumtext	CREATE TABLE `tmediumtext` (
  `id` int(11) DEFAULT NULL,
  `info` mediumtext DEFAULT NULL
) ENGINE=ELOQ DEFAULT CHARSET=utf8mb3
create table tchar (id int, info char(32) collate utf8_bin) character set utf8;
show create table tchar;
Table	Create Table
tchar	CREATE TABLE `tchar` (
  `id` int(11) DEFAULT NULL,
  `info` char(32) DEFAULT NULL
) ENGINE=ELOQ DEFAULT CHARSET=utf8mb3
create table tcharnopad (id int, info char(32) collate utf8_nopad_bin) character set utf8;
show create table tcharnopad;
Table	Create Table
tcharnopad	CREATE TABLE `tcharnopad` (
  `id` int(11) DEFAULT NULL,
  `info` char(32) CHARACTER SET utf8mb3 COLLATE utf8mb3_nopad_bin DEFAULT NULL
) ENGINE=ELOQ DEFAULT CHARSET=utf8mb3
