#
# test 3 virtual column
#
CREATE TABLE jemp (
c JSON,
e DATE NOT NULL,
g INT GENERATED ALWAYS AS (json_unquote(json_extract(c, "$.id"))),
n VARCHAR(64) GENERATED ALWAYS AS (json_unquote(json_extract(c, "$.name"))) PERSISTENT
);
INSERT INTO jemp (c, e) VALUES
('{"id": "1", "name": "Fred"}', 20211201), ('{"id": "2", "name": "Wilma"}', 20211231),
('{"id": "3", "name": "Barney"}', 20220321), ('{"id": "4", "name": "Betty"}', 20220610);
CREATE INDEX idx_g ON jemp (g);
CREATE INDEX idx_n ON jemp (n);
CREATE INDEX idx_ge ON jemp (g, e);
CREATE INDEX idx_ne ON jemp (n, e);
SHOW CREATE TABLE jemp;
Table	Create Table
jemp	CREATE TABLE `jemp` (
  `c` longtext CHARACTER SET utf8mb4 DEFAULT NULL CHECK (json_valid(`c`)),
  `e` date NOT NULL,
  `g` int(11) GENERATED ALWAYS AS (json_unquote(json_extract(`c`,'$.id'))) VIRTUAL,
  `n` varchar(64) GENERATED ALWAYS AS (json_unquote(json_extract(`c`,'$.name'))) STORED,
  KEY `idx_g` (`g`),
  KEY `idx_n` (`n`),
  KEY `idx_ge` (`g`,`e`),
  KEY `idx_ne` (`n`,`e`)
) ENGINE=ELOQ DEFAULT CHARSET=latin1
INSERT INTO jemp (c, e) VALUES
('{"id": "5", "name": "John"}', 20220712), ('{"id": "6", "name": "Pop"}', 20221012),
('{"id": "7", "name": "James"}', 20221102), ('{"id": "8", "name": "Allen"}', 20221118);
select json_unquote(json_extract(c, "$.name")) as name, e from jemp where g > 3;
name	e
Betty	2022-06-10
John	2022-07-12
Pop	2022-10-12
James	2022-11-02
Allen	2022-11-18
select json_unquote(json_extract(c, "$.name")) as name, e from jemp ignore index (idx_g) where n > "Betty";
name	e
Fred	2021-12-01
James	2022-11-02
John	2022-07-12
Pop	2022-10-12
Wilma	2021-12-31
select json_unquote(json_extract(c, "$.name")) as name, e from jemp where e > 20220101 AND g > 4;
name	e
John	2022-07-12
Pop	2022-10-12
James	2022-11-02
Allen	2022-11-18
select json_unquote(json_extract(c, "$.name")) as name, e from jemp where e > 20220101 AND n > "Barney";
name	e
Betty	2022-06-10
James	2022-11-02
John	2022-07-12
Pop	2022-10-12
