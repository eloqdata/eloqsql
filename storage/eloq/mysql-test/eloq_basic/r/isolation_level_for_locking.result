set @@default_storage_engine= eloq;
select @@default_storage_engine;
@@default_storage_engine
ELOQ
DROP TABLE IF EXISTS t1;
create table t1(i int primary key, j int) engine= eloq;
insert into t1 values(1,1);
insert into t1 values(2,1);
connect  conn-tx1,localhost,root,,test,$MONO1_PORT;
select * from t1;
i	j
1	1
2	1
connect  conn-tx2,localhost,root,,test,$MONO1_PORT;
select * from t1;
i	j
1	1
2	1
connection conn-tx1;
set session transaction isolation level repeatable read;
select @@tx_isolation;
@@tx_isolation
REPEATABLE-READ
connection conn-tx2;
set session transaction isolation level repeatable read;
select @@tx_isolation;
@@tx_isolation
REPEATABLE-READ
connection conn-tx1;
update t1 set j=2 where i=1;
select * from t1 where i=1;
i	j
1	2
update t1 set j=2 where i=2;
select * from t1 where i=2;
i	j
2	2
update t1 set j=3 where i=1;
select * from t1 where i=1;
i	j
1	3
update t1 set j=3 where i=2;
select * from t1 where i=2;
i	j
2	3
select * from t1;
i	j
1	3
2	3
"### RR test: rr-1 ###"
connection conn-tx1;
begin;
select * from t1 where i=1;
i	j
1	3
connection conn-tx2;
select * from t1 where i=1;
i	j
1	3
connection conn-tx1;
select * from t1 where i=1;
i	j
1	3
commit;
"### RR test: rw-1 ###"
connection conn-tx1;
begin;
select * from t1 where i=1;
i	j
1	3
connection conn-tx2;
update t1 set j=11 where i=1;
"send"
connection conn-tx1;
select * from t1 where i=1;
i	j
1	3
commit;
connection conn-tx2;
select * from t1 where i=1;
i	j
1	11
connection conn-tx1;
set session transaction isolation level read committed;
select @@tx_isolation;
@@tx_isolation
READ-COMMITTED
connection conn-tx2;
set session transaction isolation level read committed;
select @@tx_isolation;
@@tx_isolation
READ-COMMITTED
"### RC test: rw-1 ###"
connection conn-tx1;
insert into t1 values(11,1);
select * from t1 where i=11;
i	j
11	1
Begin;
select * from t1 where i=11;
i	j
11	1
connection conn-tx2;
update t1 set j=2 where i=11;
select * from t1 where i=11;
i	j
11	2
connection conn-tx1;
select * from t1 where i=11;
i	j
11	2
commit;
select * from t1;
i	j
1	11
2	3
11	2
"### RC test: rw-2 ###"
connection conn-tx1;
begin;
select * from t1 where i=11;
i	j
11	2
connection conn-tx2;
begin;
update t1 set j=3 where i=11;
select * from t1 where i=11;
i	j
11	3
connection conn-tx1;
select * from t1 where i=11;
i	j
11	2
connection conn-tx2;
commit;
connection conn-tx1;
"# result must be: 11,3"
select * from t1 where i=11;
i	j
11	3
commit;
select * from t1;
i	j
1	11
2	3
11	3
"### RC test: rw-3 ###"
connection conn-tx1;
insert into t1 values(12,1);
begin;
select * from t1 where i=11;
i	j
11	3
select * from t1 where i=12;
i	j
12	1
connection conn-tx2;
begin;
update t1 set j=4 where i=11;
update t1 set j=4 where i=12;
commit;
select * from t1 where i=11;
i	j
11	4
select * from t1 where i=12;
i	j
12	4
connection conn-tx1;
select * from t1 where i=11;
i	j
11	4
select * from t1 where i=12;
i	j
12	4
commit;
select * from t1;
i	j
1	11
2	3
11	4
12	4
"### RU test ###"
set session transaction isolation level read uncommitted;
select @@tx_isolation;
@@tx_isolation
READ-UNCOMMITTED
select * from t1;
ERROR HY000: Eloq: does not support 'read uncommitted' isolation level.
set session transaction isolation level read committed;
drop table t1;
