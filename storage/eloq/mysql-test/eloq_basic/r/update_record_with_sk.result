explain select * from t1 where sk2=4;
id	select_type	table	type	possible_keys	key	key_len	ref	rows	Extra
1	SIMPLE	t1	ref	sk2	sk2	5	const	#	
select * from t1 where sk2=4;
pk1	pk2	sk1	sk2	sk3
2	2	8	4	6
explain select * from t1 where sk3=10;
id	select_type	table	type	possible_keys	key	key_len	ref	rows	Extra
1	SIMPLE	t1	ALL	NULL	NULL	NULL	NULL	#	Using where
select * from t1 where sk3=10;
