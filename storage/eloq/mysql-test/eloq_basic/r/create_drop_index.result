#
# MWL#89: test introduced after Sergey Petrunia's review - test that
# keyparts wihtout index prefix are used with the IN-EXISTS strategy.
#
create table t21 (c1 int);
insert into t21 values (1), (2), (3);
create table t22 (kp1 int, kp2 int, c2 int, filler char(100));
insert into t22 values (0,0,0,'filler'),(0,1,1,'filler'),(0,2,2,'filler'),(0,3,3,'filler');
create index key1 on t22 (kp1, kp2);
create index key2 on t22 (kp1);
create index key3 on t22 (kp2);
SET @@optimizer_switch='materialization=off,semijoin=off,in_to_exists=on';
explain
select c1 from t21 where c1 in (select kp1 from t22 where kp2 = 10 and c2 = 4) or c1 > 7;
id	select_type	table	type	possible_keys	key	key_len	ref	rows	Extra
1	PRIMARY	t21	ALL	NULL	NULL	NULL	NULL	#	Using where
2	DEPENDENT SUBQUERY	t22	index_subquery|filter	key1,key2,key3	key2|key3	5|5	func	#	Using where; Using rowid filter
select c1 from t21 where c1 in (select kp1 from t22 where kp2 = 10 and c2 = 4) or c1 > 7;
c1
set @@optimizer_switch='default';
# End of subselect mat cost bugs tests
set @subselect_sj2_tmp= @@optimizer_switch;
set optimizer_switch='semijoin=on,firstmatch=on,loosescan=on';
set optimizer_switch='mrr=on,mrr_sort_keys=on,index_condition_pushdown=on';
SET optimizer_switch=ifnull(@optimizer_switch_for_subselect_sj2_test,'outer_join_with_cache=off');
SET optimizer_switch=ifnull(@optimizer_switch_for_subselect_sj2_test,'semijoin_with_cache=off');
set join_cache_level=1;
