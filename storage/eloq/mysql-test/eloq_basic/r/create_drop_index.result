drop procedure if exists proc_bug19733|
drop procedure if exists bug10656_create_index|
create table t4 (s1 int)|
create procedure proc_bug19733()
begin
declare v int default 0;
while v < 100 do
create index i on t4 (s1);
drop index i on t4;
set v = v + 1;
end while;
end|
call proc_bug19733()|
call proc_bug19733()|
call proc_bug19733()|
