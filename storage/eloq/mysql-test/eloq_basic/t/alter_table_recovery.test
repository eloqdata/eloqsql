#
--source include/have_eloq.inc
--source include/long_test.inc
--source include/have_range_partition.inc

--disable_warnings
DROP DATABASE IF EXISTS mono_test;
--enable_warnings
--enable_info
set @@default_storage_engine= eloq;

CREATE DATABASE IF NOT EXISTS mono_test;

USE mono_test;

--echo ###************************************************************###
--echo ###             Test CREATE INDEX
--echo ###************************************************************###

--echo #
--echo # Test 1: test recovery during add index.
--echo #
CREATE TABLE t1 (c0 INT PRIMARY KEY, c1 CHAR(200), c2 VARCHAR(200), c3 TEXT, c4 INT);
SHOW CREATE TABLE t1;
--echo Insert data...
let $counter= 0;
--disable_query_log
--disable_result_log
while($counter < 10000)
{
    let $charv= charvalue_$counter;
    let $varcharv= varcharvalue_$counter;
    let $textp= _textvalues;
    let $ftextv= $counter$textp;
    let $q=INSERT INTO t1 VALUES ($counter + 1, '$charv', '$varcharv', '$ftextv', $counter);
    eval $q;
    inc $counter;
}
--enable_result_log
--enable_query_log

# count is 10000
SELECT count(*) FROM t1;

--echo # 1.1 crash after flush prepare log.
# Write file to make mysql-test-run.pl expect crash
--exec echo "restart" > $MYSQLTEST_VARDIR/tmp/mysqld.1.expect

SET SESSION debug_dbug="+d,eloq;term_AlterTableIndex_PrepareCommitAllWLOp;node_id=-1;action=panic";
--error 2013
CREATE INDEX idx_c1 ON t1(c1);

--enable_reconnect
--source include/wait_until_connected_again.inc

--disable_abort_on_error
--disable_result_log
USE mono_test;

--let $res= 0
--let $max_loop= 10
while (! $res)
{
    --sleep 5
    --let $res= `SHOW INDEX FROM t1 WHERE key_name='idx_c1'`
    --dec $max_loop
    if (! $max_loop)
    {
        # break this loop if do not find expected index yet.
        if (! $res)
        {
            --let $res= 404
        }
    }
}

if ( $res == 404)
{
    --die ERROR: Recovery for creating index idx_c1 failed.
}

--enable_result_log
--enable_abort_on_error

SHOW CREATE TABLE t1;

INSERT INTO t1 VALUES (10001, 'char_after_index_c1', 'varchar_after_index_c1', 'text_after_index_c1', 10000),
(10002, 'char_after_index_c1', 'varchar_after_index_c1', 'text_after_index_c1', 10001),
(10003, 'char_after_index_c1', 'varchar_after_index_c1', 'text_after_index_c1', 10002),
(10004, 'char_after_index_c1', 'varchar_after_index_c1', 'text_after_index_c1', 10003);

# count is 10004
SELECT count(*) FROM t1 FORCE INDEX(idx_c1);

--echo # 1.2 crash before flush new packed sk into data store.
# Write file to make mysql-test-run.pl expect crash
--exec echo "restart" > $MYSQLTEST_VARDIR/tmp/mysqld.1.expect

SET SESSION debug_dbug="+d,eloq;term_AlterTableIndex_FlushNewPackedSKOp;node_id=-1;action=panic";
--error 2013
CREATE INDEX idx_c4 ON t1(c4);

--enable_reconnect
--source include/wait_until_connected_again.inc

--disable_abort_on_error
--disable_result_log
USE mono_test;

--let $res= 0
--let $max_loop= 10
while (! $res)
{
    --sleep 5
    --let $res= `SHOW INDEX FROM t1 WHERE key_name='idx_c4'`
    --dec $max_loop
    if (! $max_loop)
    {
        # break this loop if do not find expected index yet.
        if (! $res)
        {
            --let $res= 404
        }
    }
}

if ( $res == 404)
{
    --die ERROR: Recovery for creating index idx_c4 failed.
}

--enable_result_log
--enable_abort_on_error

SHOW CREATE TABLE t1;

INSERT INTO t1 VALUES (10013, 'char_after_index_c4', 'varchar_after_index_c4', 'text_after_index_c4', 10012),
(10014, 'char_after_index_c4', 'varchar_after_index_c4', 'text_after_index_c4', 10013),
(10015, 'char_after_index_c4', 'varchar_after_index_c4', 'text_after_index_c4', 10014),
(10016, 'char_after_index_c4', 'varchar_after_index_c4', 'text_after_index_c4', 10015);

# count is 10008
SELECT count(*) FROM t1 FORCE INDEX(idx_c4);

--echo # 1.3 crash before flush prepare index table log(after flush new packed sk into kv).
# Write file to make mysql-test-run.pl expect crash
--exec echo "restart" > $MYSQLTEST_VARDIR/tmp/mysqld.1.expect

SET SESSION debug_dbug="+d,eloq;term_AlterTableIndex_FlushPrepareIndexTableLogOp;node_id=-1;action=panic";
--error 2013
CREATE INDEX idx_c4c1 ON t1(c4,c1);

--enable_reconnect
--source include/wait_until_connected_again.inc

--disable_abort_on_error
--disable_result_log
USE mono_test;

--let $res= 0
--let $max_loop= 10
while (! $res)
{
    --sleep 5
    --let $res= `SHOW INDEX FROM t1 WHERE key_name='idx_c4c1'`
    --dec $max_loop
    if (! $max_loop)
    {
        # break this loop if do not find expected index yet.
        if (! $res)
        {
            --let $res= 404
        }
    }
}

if ( $res == 404)
{
    --die ERROR: Recovery for creating index idx_c4c1 failed.
}

--enable_result_log
--enable_abort_on_error

SHOW CREATE TABLE t1;

INSERT INTO t1 VALUES (10017, 'char_after_index_c4c1', 'varchar_after_index_c4c1', 'text_after_index_c4c1', 10016),
(10018, 'char_after_index_c4c1', 'varchar_after_index_c4c1', 'text_after_index_c4c1', 10017),
(10019, 'char_after_index_c4c1', 'varchar_after_index_c4c1', 'text_after_index_c4c1', 10018),
(10020, 'char_after_index_c4c1', 'varchar_after_index_c4c1', 'text_after_index_c4c1', 10019);

# count is 10012
SELECT count(*) FROM t1 FORCE INDEX(idx_c4c1);

--echo # 1.4 crash after flush commit log.
# Write file to make mysql-test-run.pl expect crash
--exec echo "restart" > $MYSQLTEST_VARDIR/tmp/mysqld.1.expect

SET SESSION debug_dbug="+d,eloq;term_AlterTableIndex_PostCommitAllWLOp;node_id=-1;action=panic";
--error 2013
CREATE INDEX idx_c3 ON t1(c3(128));

--enable_reconnect
--source include/wait_until_connected_again.inc

--disable_abort_on_error
--disable_result_log
USE mono_test;

--let $res= 0
--let $max_loop= 10
while (! $res)
{
    --sleep 5
    --let $res= `SHOW INDEX FROM t1 WHERE key_name='idx_c3'`
    --dec $max_loop
    if (! $max_loop)
    {
        # break this loop if do not find expected index yet.
        if (! $res)
        {
            --let $res= 404
        }
    }
}

if ( $res == 404)
{
    --die ERROR: Recovery for creating index idx_c3 failed.
}

--enable_result_log
--enable_abort_on_error

SHOW CREATE TABLE t1;

INSERT INTO t1 VALUES (10009, 'char_after_index_c3', 'varchar_after_index_c3', 'text_after_index_c3', 10008),
(10010, 'char_after_index_c3', 'varchar_after_index_c3', 'text_after_index_c3', 10009),
(10011, 'char_after_index_c3', 'varchar_after_index_c3', 'text_after_index_c3', 10010),
(10012, 'char_after_index_c3', 'varchar_after_index_c3', 'text_after_index_c3', 10011);

# count is 10016
SELECT count(*) FROM t1 FORCE INDEX(idx_c3);

--echo #
--echo # Test 2: test data store operation failed during add index.
--echo #
## fault injection
SET SESSION debug_dbug="+d,eloq;trigger_flush_kv_error;node_id=-1";
## handle flush kv error
--error 210 # ERROR 210 (HY000): Eloq: failed to create index.
CREATE INDEX idx_c3c4 ON t1(c3(256), c4);
--error 1176 # ER_KEY_DOES_NOT_EXISTS (1176)
SELECT * FROM t1 FORCE INDEX(idx_c3c4);
SET SESSION debug_dbug="-d,eloq;trigger_flush_kv_error";

# successfully.
CREATE INDEX idx_c3c4 ON t1(c3(256), c4);
SHOW CREATE TABLE t1;

--echo ###************************************************************###
--echo ###             Test logical update table
--echo ###************************************************************###

--echo #
--echo # Test 3: test crash after prepare log
--echo #
CREATE TABLE t2(i INT PRIMARY KEY);

--exec echo "restart" > $MYSQLTEST_VARDIR/tmp/mysqld.1.expect
SET SESSION debug_dbug="+d,eloq;upsert_table_crash_after_prepare_log;node_id=-1;action=panic";
--error 2013
ALTER TABLE t2 COMMENT 'Test logical update table crash after prepare log';

--enable_reconnect
--source include/wait_until_connected_again.inc

USE mono_test;
SHOW CREATE TABLE t2;

--echo #
--echo # Test 4: test crash after commit log
--echo #

--exec echo "restart" > $MYSQLTEST_VARDIR/tmp/mysqld.1.expect
SET SESSION debug_dbug="+d,eloq;upsert_table_post_all_lock;node_id=-1;action=panic";
--error 2013
ALTER TABLE t2 MODIFY COLUMN i INT COMMENT 'Test logical update table crash after commit log';

--enable_reconnect
--source include/wait_until_connected_again.inc

USE mono_test;
SHOW CREATE TABLE t2;


--echo #
--echo # Test 5: test DROP INDEX recovery after commit log
--echo #

SHOW CREATE TABLE t1;

--exec echo "restart" > $MYSQLTEST_VARDIR/tmp/mysqld.1.expect
SET SESSION debug_dbug="+d,eloq;term_AlterTableDropIndex_PostCommitAllWLOp;node_id=-1;action=panic";
--error 2013
DROP INDEX idx_c4c1 ON t1;

--enable_reconnect
--source include/wait_until_connected_again.inc

USE mono_test;
SHOW CREATE TABLE t1;


--echo # Clean up
DROP DATABASE IF EXISTS mono_test;

--disable_info
