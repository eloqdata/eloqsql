--source include/have_eloq.inc

# Eloq commit transaction via create.
CREATE TEMPORARY TABLE t1 (i INT PRIMARY KEY, j INT) ENGINE=eloq;
CREATE TEMPORARY TABLE t2 (i INT PRIMARY KEY, k INT) ENGINE=eloq;
INSERT INTO t1 VALUES (1, 3);
INSERT INTO t2 VALUES (2, 4);

# Eloq commit transaction via external_lock.
SELECT * from t1, t2;

# Eloq commit transaction via commit
START TRANSACTION;
SELECT * from t1, t2;
COMMIT;

# Eloq commit transaction via commit
START TRANSACTION;
CREATE OR REPLACE TEMPORARY TABLE t1 (i INT PRIMARY KEY, j INT) ENGINE=eloq;
INSERT INTO t1 VALUES (1, 5);
SELECT * from t1, t2;
COMMIT;

DROP TABLE t1, t2;

# Create a proc which create or replace a temporary table.
delimiter $$;
CREATE PROCEDURE p1(IN n INT)
BEGIN
  CREATE OR REPLACE TEMPORARY TABLE t1 (i int primary key, j INT);
  CREATE OR REPLACE TEMPORARY TABLE t2 (i int primary key, k INT);
  INSERT INTO t1 VALUES (n, n*1);
  INSERT INTO t2 VALUES (n, n*2);
  SELECT * from t1, t2;
END;
$$
delimiter ;$$

CALL p1(1);
CALL p1(2);

DROP PROCEDURE p1;
DROP TABLE t1, t2;