--source include/have_eloq.inc

# Exec CRUD on temporary table.
CREATE TEMPORARY TABLE temp_table_1(i int primary key, j int) ENGINE=eloq;
INSERT INTO temp_table_1(i, j) VALUES(1,1),(2,2),(3,3);
SELECT * FROM temp_table_1 WHERE i=1;
INSERT temp_table_1(i, j) VALUES(2, 200) on duplicate key update j=200;
SELECT * FROM temp_table_1;
UPDATE temp_table_1 SET j=0;
SELECT * FROM temp_table_1;

# Create temporary table with same name in same session.
--error ER_TABLE_EXISTS_ERROR
CREATE TEMPORARY TABLE temp_table_1(i int primary key, j int) ENGINE=eloq;
DROP TABLE temp_table_1;
CREATE TEMPORARY TABLE temp_table_1(i int primary key, j int) ENGINE=eloq;

# Create temporary table with same name in another session.
--connect (conn,localhost,root,,test)
CREATE TEMPORARY TABLE temp_table_1(i int primary key, j int) ENGINE=eloq;

# Restart server normally. Temporary tables would be dropped automatically.
SELECT count(*) FROM INFORMATION_SCHEMA.ELOQ_TEMP_TABLE_INFO;
--source include/restart_mysqld.inc
SELECT count(*) FROM INFORMATION_SCHEMA.ELOQ_TEMP_TABLE_INFO;

# Kill and restart server. Temporary tables would be dropped automatically.
CREATE TEMPORARY TABLE temp_table_1(i int primary key, j int) ENGINE=eloq;
SELECT count(*) FROM INFORMATION_SCHEMA.ELOQ_TEMP_TABLE_INFO;
--source include/kill_and_restart_mysqld.inc
SELECT count(*) FROM INFORMATION_SCHEMA.ELOQ_TEMP_TABLE_INFO;
