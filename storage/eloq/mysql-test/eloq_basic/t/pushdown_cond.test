--echo # Test BINARY type
select id, hex(info) from tbinary where info=1234567890;
select id, hex(info) from tbinary where info='1234567890';
select id, hex(info) from tbinary where info='1234567890\0\0\0\0\0\0';
select id, hex(info) from tbinary where info='1234567890 ';
select id, hex(info) from tbinary where info='1234567890 \0\0\0\0\0';
select id, hex(info) from tbinary where info='诚招加盟商';
select id, hex(info) from tbinary where info='诚招加盟商\0';
select id, hex(info) from tbinary where info='asdfghjASDFGH';
select id, hex(info) from tbinary where info='asdfghjASDFGH\0\0\0';
select id, hex(info) from tbinary where info=0xaabbccddeeff00;
select id, hex(info) from tbinary where info=0xaabbccddeeff00000000000000000000;
select id, hex(info) from tbinary where info like 1234567890;
select id, hex(info) from tbinary where info like '1234567890';
select id, hex(info) from tbinary where info like '1234567890\0\0\0\0\0\0';
select id, hex(info) from tbinary where info like 'asdfghjASDFGH';
select id, hex(info) from tbinary where info like 'asdfghjASDFGH\0\0\0';
select id, hex(info) from tbinary where info like 0xaabbccddeeff00;
select id, hex(info) from tbinary where info like 0xaabbccddeeff00000000000000000000;
select id, hex(info) from tbinary where info is null;

