--echo ##
--echo ## Test NO PAD collation
--echo ##
set names utf8;
create table tvarcharnopad (id int, info varchar(16) collate utf8_nopad_bin) character set utf8;
show create table tvarcharnopad;
create table tvarchar (id int, info varchar(16) collate utf8_bin) character set utf8;
show create table tvarchar;

create table tmediumtextnopad (id int, info mediumtext collate utf8_nopad_bin) character set utf8;
show create table tmediumtextnopad;
create table tmediumtext (id int, info mediumtext collate utf8_bin) character set utf8;
show create table tmediumtext;

create table tchar (id int, info char(32) collate utf8_bin) character set utf8;
show create table tchar;
create table tcharnopad (id int, info char(32) collate utf8_nopad_bin) character set utf8;
show create table tcharnopad;

insert into tvarcharnopad values (1, 'qwertASDFG'),(2, 'qwertASDFG  '),(3, '诚招加盟商加盟'),(4, '诚招加盟商加盟  ');
select id, info, hex(info) from tvarcharnopad;
insert into tvarchar values (1, 'qwertASDFG'),(2, 'qwertASDFG  '),(3, '诚招加盟商加盟'),(4, '诚招加盟商加盟  ');
select id, info, hex(info) from tvarchar;

insert into tmediumtextnopad values (1, 'qwertASDFG'),(2, 'qwertASDFG  '),(3, '诚招加盟商加盟'),(4, '诚招加盟商加盟  ');
select id, info, hex(info) from tmediumtextnopad; 
insert into tmediumtext values (1, 'qwertASDFG'),(2, 'qwertASDFG  '),(3, '诚招加盟商加盟'),(4, '诚招加盟商加盟  ');
select id, info, hex(info) from tmediumtext;

insert into tchar values (1, 'qwertASDFG'),(2,'qwertASDFG  '),(3, '诚招加盟商加盟'), (4, '诚招加盟商加盟  ');
select id, info, hex(info) from tchar;
insert into tcharnopad values (1, 'qwertASDFG'),(2,'qwertASDFG  '),(3, '诚招加盟商加盟'), (4, '诚招加盟商加盟  ');
select id, info, hex(info) from tcharnopad;

# restart server
--source include/restart_mysqld.inc
set global eloq_report_debug_info=1;

SET @old_cs_client = @@character_set_client;
SET @old_cs_results = @@character_set_results;
SET @old_cs_connection = @@character_set_connection;
set names utf8;

--echo # VARCHAR type
select id, info, hex(info) from tvarcharnopad where info='qwertASDFG';
select id, info, hex(info) from tvarcharnopad where info='诚招加盟商加盟  ';
select id, info, hex(info) from tvarchar where info='qwertASDFG';
