select id, hex(info) from tvarbinary where info like 1234567890;
select id, hex(info) from tvarbinary where info like '1234567890';
select id, hex(info) from tvarbinary where info like '1234567890 ';
select id, hex(info) from tvarbinary where info like 0xaabbccddeeff00;
select id, hex(info) from tvarbinary where info is null;

