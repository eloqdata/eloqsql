--echo # With PAD_CHAR_TO_FULL_LENGTH
set @old_sql_mode=@@session.sql_mode;
set @@session.sql_mode='STRICT_TRANS_TABLES,ERROR_FOR_DIVISION_BY_ZERO,NO_AUTO_CREATE_USER,NO_ENGINE_SUBSTITUTION,PAD_CHAR_TO_FULL_LENGTH';

select id, info, hex(info) from tchar where info='qwertASDFG';
select id, info, hex(info) from tchar where info='诚招加盟商加盟  ';

select id, info, hex(info) from tcharnopad where info='qwertASDFG';
select id, info, hex(info) from tcharnopad where info='qwertASDFG                      ';

select id, info, hex(info) from tcharnopad where info='诚招加盟商加盟  ';
select id, info, hex(info) from tcharnopad where info='诚招加盟商加盟                         ';

# clean up
set global eloq_report_debug_info=0;
set @@session.sql_mode=@old_sql_mode;
SET character_set_client = @old_cs_client;
SET character_set_results = @old_cs_results;
SET character_set_connection = @old_cs_connection;
drop table tvarcharnopad, tvarchar, tmediumtextnopad, tmediumtext, tchar, tcharnopad;
