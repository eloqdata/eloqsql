--source include/have_eloq.inc

set @@default_storage_engine= eloq;
select @@default_storage_engine;

--disable_warnings
DROP TABLE IF EXISTS t2;
--enable_warnings

create table t2(i int primary key, j int) engine= eloq;

insert into t2 values(1,1);
insert into t2 values(2,2);
insert into t2 values(3,3);
insert into t2 values(5,5);
insert into t2 values(7,7);

select * from t2 where i<3;      # 1,1 | 2,2
select * from t2 where i<=3;     # 1,1 | 2,2 | 3,3
select * from t2 where i>5;      # 7,7
select * from t2 where i>=5;     # 5,5 | 7,7
select * from t2;                # 1,1 | 2,2 | 3,3 | 5,5 | 7,7

SET SESSION debug_dbug="+d,eloq;stop_safely_clean_archives;";
update t2 set j=11;
update t2 set j=12;
update t2 set j=13;
select * from t2;      # 1,13 | 2,13 | 3,13 | 5,13 | 7,13

## under SI/RR isolation level

#### test mvcc PkScan
set session transaction isolation level repeatable read;
select @@tx_isolation;

--connect (conn-tx1,localhost,root,,test,$MONO1_PORT)
set session transaction isolation level repeatable read;
select @@tx_isolation;

begin;
select * from t2 where i<3;      # 1,13 | 2,13
select * from t2 where i<=3;     # 1,13 | 2,13 | 3,13
select * from t2 where i>5;      # 7,13
select * from t2 where i>=5;     # 5,13 | 7,13
select * from t2;                # 1,13 | 2,13 | 3,13 | 5,13 | 7,13

--connection default
update t2 set j=21 where i=1;
update t2 set j=22 where i=2;
update t2 set j=23 where i=3;
update t2 set j=25 where i=5;
delete from t2 where i=7;
insert into t2 values(8,28);
select * from t2;      # 1,21 | 2,22| 3,23 | 5,25 | 8,28

--connection conn-tx1
select * from t2 where i<3;      # 1,13 | 2,13
select * from t2 where i<=3;     # 1,13 | 2,13 | 3,13
select * from t2 where i>5;      # 7,13
select * from t2 where i>=5;     # 5,13 | 7,13
select * from t2;                # 1,13 | 2,13 | 3,13 | 5,13 | 7,13


#### test mvcc PkScan after kickout archives
--connection default
# kickout archives:  flush archives, clean archives, check archives in store, check read tx rq return VersionUnkonwn 
SET SESSION debug_dbug="+d,eloq_test;archives_clean_test;./test/t2;2;";
SET SESSION debug_dbug="+d,eloq_test;archives_clean_test;./test/t2;5;";
SET SESSION debug_dbug="+d,eloq_test;archives_clean_test;./test/t2;3;";

--connection conn-tx1
select * from t2 where i<3;      # 1,13 | 2,13
select * from t2 where i>=5;     # 5,13 | 7,13
select * from t2;                # 1,13 | 2,13 | 3,13 | 5,13 | 7,13
commit;

select * from t2;      # 1,21 | 2,22| 3,23 | 5,25 | 8,28

## under RC isolation level

#### test mvcc PkScan

update t2 set j=30;

--connection conn-tx1
set session transaction isolation level read committed;
select @@tx_isolation;

begin;
select * from t2 where i<3;      # 1,30 | 2,30
select * from t2 where i<=3;     # 1,30 | 2,30 | 3,30
select * from t2 where i>5;      # 8,30
select * from t2 where i>=5;     # 5,30 | 8,30
select * from t2;                # 1,30 | 2,30 | 3,30 | 5,30 | 8,30


--connection default
set session transaction isolation level read committed;
select @@tx_isolation;
delete from t2 where i=1;
update t2 set j=33 where i=3;
update t2 set j=38 where i=8;
insert into t2 values(9,39);

select * from t2;       # 2,30 | 3,33 | 5,30 | 8,38 | 9,39

--connection conn-tx1
select * from t2 where i<3;      # 2,30
select * from t2 where i<=3;     # 2,30 | 3,33
select * from t2 where i>5;      # 8,38 | 9,39
select * from t2 where i>=5;     # 5,30 | 8,38 | 9,39
select * from t2;                # 2,30 | 3,33 | 5,30 | 8,38 | 9,39

#### test mvcc PkScan after kickout archives
--connection default
# kickout archives:  flush archives, clean archives, check archives in store, check read tx rq return VersionUnkonwn
SET SESSION debug_dbug="+d,eloq_test;archives_clean_test;./test/t2;1;";
SET SESSION debug_dbug="+d,eloq_test;archives_clean_test;./test/t2;3;";

--connection conn-tx1
select * from t2 where i<3;      # 2,30
select * from t2 where i<=3;     # 2,30 | 3,33
select * from t2 where i>5;      # 8,38 | 9,39
select * from t2 where i>=5;     # 5,30 | 8,38 | 9,39
select * from t2;                # 2,30 | 3,33 | 5,30 | 8,38 | 9,39
commit;

SET SESSION debug_dbug="-d,eloq;stop_safely_clean_archives;";
drop table t2;