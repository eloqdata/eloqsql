--source include/have_eloq.inc

--disable_warnings
DROP TABLE IF EXISTS t1;
--enable_warnings

# Test ha interface: position() and rnd_pos()
CREATE TABLE t1 (pk int primary key, j decimal(5,2));
# precision 5, scale 2 -> maximum value is 999.99
--error 1264
INSERT INTO t1 VALUES(1,1000.001);
# test kv store, restart engine to clear ccmap and force checkpoint
INSERT INTO t1 VALUES (1,10.012),(2,0.00),(3,0.01),(4,0.10),(5,0.1),(6,1.1111),(7,1.116);

--echo # unsigned mediumint test
create table tum (umedium mediumint(8) unsigned DEFAULT '0' NOT NULL);

insert ignore into tum values (1),(2),(3),(-1),(-4294967295),(4294967295);

SELECT * FROM tum;

--source include/restart_mysqld.inc
SELECT * FROM t1;

SELECT * FROM tum;

DROP TABLE t1, tum;

