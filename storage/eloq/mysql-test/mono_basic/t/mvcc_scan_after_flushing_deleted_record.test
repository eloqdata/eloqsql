--source include/have_eloq.inc

set @@default_storage_engine= eloq;
select @@default_storage_engine;

--disable_warnings
DROP TABLE IF EXISTS t1;
--enable_warnings

SET SESSION debug_dbug="+d,eloq;checkpointer_skip_ckpt;node_id=-1";
SET SESSION debug_dbug="+d,eloq;stop_safely_clean_archives;";

create table t1(i int primary key, j int) engine= eloq;

insert into t1 values(1,1);
insert into t1 values(2,2);
insert into t1 values(3,3);
insert into t1 values(5,5);
insert into t1 values(7,7);
insert into t1 values(8,8);

select * from t1 where i<3;      # 1,1 | 2,2
select * from t1 where i<=3;     # 1,1 | 2,2 | 3,3
select * from t1 where i>5;      # 7,7 | 8,8
select * from t1 where i>=5;     # 5,5 | 7,7 | 8,8
select * from t1;                # 1,1 | 2,2 | 3,3 | 5,5 | 7,7 | 8,8


## under SI/RR isolation level

#### test mvcc PkScan
set session transaction isolation level repeatable read;
select @@tx_isolation;

--connect (conn-tx1,localhost,root,,test,$MONO1_PORT)
set session transaction isolation level repeatable read;
select @@tx_isolation;

begin;
select * from t1 where i<3;      # 1,1 | 2,2
select * from t1 where i<=3;     # 1,1 | 2,2 | 3,3
select * from t1 where i>5;      # 7,7 | 8,8
select * from t1 where i>=5;     # 5,5 | 7,7 | 8,8
select * from t1;                # 1,1 | 2,2 | 3,3 | 5,5 | 7,7 | 8,8

--connection default
update t1 set j=21;
update t1 set j=22;
delete from t1 where i=1;
update t1 set j=23 where i=3;
update t1 set j=25 where i=5;
delete from t1 where i=7;
insert into t1 values(9,29);
select * from t1;      # 2,22| 3,23 | 5,25 | 8,22 | 9,29

--connection conn-tx1
select * from t1 where i<3;      # 1,1 | 2,2
select * from t1 where i<=3;     # 1,1 | 2,2 | 3,3
select * from t1 where i>5;      # 7,7 | 8,8
select * from t1 where i>=5;     # 5,5 | 7,7 | 8,8
select * from t1;                # 1,1 | 2,2 | 3,3 | 5,5 | 7,7 | 8,8


#### test mvcc PkScan after flushing and cleanning "deleted" ccentry.
--connection default
# kickout ccentry:  flush archives and latest version, clean ccentry, check archives and latest version in store,
#    check read tx req return Unkonwn 
SET SESSION debug_dbug="+d,eloq_test;ccentry_clean_test;./test/t1;1;";
SET SESSION debug_dbug="+d,eloq_test;ccentry_clean_test;./test/t1;7;";
SET SESSION debug_dbug="+d,eloq_test;ccentry_clean_test;./test/t1;3;";

select * from t1;      # 2,22| 3,23 | 5,25 | 8,22 | 9,29

--connection conn-tx1
select * from t1 where i<3;      # 1,1 | 2,2
select * from t1 where i<=3;     # 1,1 | 2,2 | 3,3
select * from t1 where i>5;      # 7,7 | 8,8
select * from t1 where i>=5;     # 5,5 | 7,7 | 8,8
select * from t1;                # 1,1 | 2,2 | 3,3 | 5,5 | 7,7 | 8,8
commit;

select * from t1;      # 2,22| 3,23 | 5,25 | 8,22 | 9,29

## under RC isolation level

#### test mvcc PkScan

update t1 set j=30;

--connection conn-tx1
set session transaction isolation level read committed;
select @@tx_isolation;

begin;
select * from t1 where i<3;      # 2,30
select * from t1 where i<=3;     # 2,30 | 3,30
select * from t1 where i>5;      # 8,30 | 9,30
select * from t1 where i>=5;     # 5,30 | 8,30 | 9,30
select * from t1;                # 2,30 | 3,30 | 5,30 | 8,30 | 9,30


--connection default
set session transaction isolation level read committed;
select @@tx_isolation;
delete from t1 where i=2;
delete from t1 where i=5;
update t1 set j=33 where i=3;
update t1 set j=38 where i=8;

select * from t1;       # 3,33 | 8,38 | 9,30

--connection conn-tx1
select * from t1 where i<3;      #
select * from t1 where i<=3;     # 3,33
select * from t1 where i>5;      # 8,38 | 9,30
select * from t1 where i>=5;     # 8,38 | 9,39
select * from t1;                # 3,33 | 8,38 | 9,30


#### test mvcc PkScan after flushing and cleanning "deleted" ccentry.
--connection default
# kickout ccentry:  flush archives and latest version, clean ccentry, check archives and latest version in store,
#    check read tx req return Unkonwn 
SET SESSION debug_dbug="+d,eloq_test;ccentry_clean_test;./test/t1;2;";
SET SESSION debug_dbug="+d,eloq_test;ccentry_clean_test;./test/t1;5;";

--connection conn-tx1
select * from t1 where i<3;      #
select * from t1 where i<=3;     # 3,33
select * from t1 where i>5;      # 8,38 | 9,30
select * from t1 where i>=5;     # 8,38 | 9,39
select * from t1;                # 3,33 | 8,38 | 9,30
commit;

SET SESSION debug_dbug="-d,eloq;stop_safely_clean_archives;";
SET SESSION debug_dbug="-d,eloq;checkpointer_skip_ckpt;node_id=-1";
drop table t1;