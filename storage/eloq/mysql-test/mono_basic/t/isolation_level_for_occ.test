--source include/have_eloq.inc

set @@default_storage_engine= eloq;
select @@default_storage_engine;

--disable_warnings
DROP TABLE IF EXISTS t1;
--enable_warnings

create table t1(i int primary key, j int) engine= eloq;

insert into t1 values(1,1);
insert into t1 values(2,1);

--connect (conn-tx1,localhost,root,,test,$MONO1_PORT)
select * from t1;        # 1,1 | 2,1
--connect (conn-tx2,localhost,root,,test,$MONO1_PORT)
select * from t1;        # 1,1 | 2,1

####### repeatable read (OCC) #######
--connection conn-tx1
set session transaction isolation level repeatable read;
select @@tx_isolation;
--connection conn-tx2
set session transaction isolation level repeatable read;
select @@tx_isolation;

--connection conn-tx1

## no conflict##
update t1 set j=2 where i=1;
select * from t1 where i=1;  # 1,2
update t1 set j=2 where i=2;
select * from t1 where i=2;  # 2,2
update t1 set j=3 where i=1;
select * from t1 where i=1;  # 1,3
update t1 set j=3 where i=2;
select * from t1 where i=2;  # 2,3

select * from t1;            # 1,3 | 2,3

## rw-1
# tx1 [b-r(i=1) -            - r(i=1)-c]
# tx2 [         - b/w(i=1)/c -         ]
## result: tx2 success, second read of tx1 fail for break repeatable read.

--connection conn-tx1
begin;
select * from t1 where i=1;  # 1,3

--connection conn-tx2
update t1 set j=11 where i=1;
select * from t1 where i=1;  # 1,11

--connection conn-tx1
--error 214
select * from t1 where i=1;  # error: for read-write conflict exists, validate error while read
commit;

select * from t1;            # 1,11 | 2,3

## rw-2
## tx1: [b-r(i=1) -            - w(i=1)-c]
## tx2: [         - b/w(i=1)/c -         ]
## result: tx2 success, write of tx1 fail for w-w conflict.
--connection conn-tx1
begin;
select * from t1 where i=1;    # 1,11

--connection conn-tx2
update t1 set j=12 where i=1;
select * from t1 where i=1;    # 1,12

--connection conn-tx1
--error 214
update t1 set j=13 where i=1;  # error: for read-write conflict exists, validate error when add read set after ReadForWrite
commit;

select * from t1;       # 1,12 | 2,3

## rw-3
## tx1 : [b-r(i=1) -            - w(i=2)-r(i=1)-c]
## tx2 : [         - b/w(i=1)/c -                ]
## result: tx2 success, second read of tx1 fail for break repeatable read.
--connection conn-tx1
begin;
select * from t1 where i=1;    # 1,12

--connection conn-tx2
update t1 set j=14 where i=1;
select * from t1 where i=1;    # 1,14

--connection conn-tx1
update t1 set j=10 where i=2;
error 214;
select * from t1 where i=1;    # error: for read-write conflict exists, validate error while read
commit;

select * from t1;      # 1,14 | 2,3

## rw-4
## tx1: [b-r(i=1) -            - w(i=2)-c]
## tx2: [         - b/w(i=1)/c -         ]
## result: tx2 success, tx1 fail for break repeatable read when commit.
--connection conn-tx1
begin;
select * from t1 where i=1;    # 1,14

--connection conn-tx2
update t1 set j=15 where i=1;
select * from t1 where i=1;    # 1,15

--connection conn-tx1
update t1 set j=15 where i=2;
error 199;
commit;               # error: for read-write conflict exists, validate error during committing    

select * from t1;     # 1,15 | 2,3


## rw-5
## tx1 : [b-r(i=1) -                   - w(i=3)-r(i=1)-r(i=2)-w(i=2)-c]
## tx2 : [         - b-w(i=1)-w(i=2)-c -                              ]
## result: tx2 success, second read of tx1 fail for break repeatable read.
--connection conn-tx1
insert into t1 values(3,1);
begin;
select * from t1 where i=1;    # 1,15

--connection conn-tx2
begin;
update t1 set j=16 where i=1;
update t1 set j=16 where i=2;
commit;
select * from t1;     # 1,16 | 2,16 | 3,1

--connection conn-tx1
update t1 set j=2 where i=3;
error 214;
select * from t1 where i=1;    # error: for read-write conflict exists, tx abort under OCC
#select * from t1 where i=2;    # error: for read-write conflict exists, tx abort under OCC
#update t1 set j=17 where i=2;
commit;

select * from t1;     # 1,16 | 2,16 | 3,1

## w-w
## tx1 : [b-w(i=1) -            - c ]
## tx2 : [         - b-w(i=1)-c -  ]
## result: tx2 fails to acquire WriteIntent when do read before update.
--connection conn-tx1
begin;
update t1 set j=18 where i=1;

--connection conn-tx2
--error 213
update t1 set j=19 where i=1;   # fail to acquire WriteIntent.

select * from t1 where i=1;     # 1,16

--connection conn-tx1
commit;
select * from t1 where i=1;    # 1,18

####### read committed #######
--connection conn-tx1
set session transaction isolation level read committed;
select @@tx_isolation;
--connection conn-tx2
set session transaction isolation level read committed;
select @@tx_isolation;

## rw-1
## tx1 : [b-r(i=1) -            - r(i=1)-c ]
## tx2 : [         - b-w(i=1)-c -          ]
## result: tx1,tx2 success
--connection conn-tx1
insert into t1 values(11,1);
select * from t1 where i=11;     # 11,1

Begin;
select * from t1 where i=11;     # 11,1

--connection conn-tx2
update t1 set j=2 where i=11;
select * from t1 where i=11;     # 11,2

--connection conn-tx1
--echo "# result must be: 11,2"
select * from t1 where i=11;     # 11,2
commit;

select * from t1;     # 1,18 | 2,16 | 3,1 | 11,2

## rw-2
## tx1 : [b-r(i=1) -          - r(i=1) -   - r(i=1)- c ]
## tx2 : [         - b-w(i=1) -        - c -           ]
## result: tx1,tx2 success

--connection conn-tx1
begin;
select * from t1 where i=11;     # 11,2

--connection conn-tx2
begin;
update t1 set j=3 where i=11;
select * from t1 where i=11;     # 11,3

--connection conn-tx1
select * from t1 where i=11;     # 11,2

--connection conn-tx2
commit;

--connection conn-tx1
--echo "# result must be: 11,3"
select * from t1 where i=11;     # 11,3
commit;

select * from t1;     # 1,19 | 2,16 | 3,1 | 11,3


## rw-3
## tx1 : [b-r(i=1)-r(i=2) -            - r(i=1)-r(i=2)- c ]
## tx2 : [         - b-w(i=1)-w(i=2)-c -                  ]
## result: tx1,tx2 success

--connection conn-tx1
insert into t1 values(12,1);
begin;
select * from t1 where i=11;     # 11,3
select * from t1 where i=12;     # 12,1

--connection conn-tx2
begin;
update t1 set j=4 where i=11;
update t1 set j=4 where i=12;
commit;
select * from t1 where i=11;     # 11,4
select * from t1 where i=12;     # 12,4

--connection conn-tx1
select * from t1 where i=11;     # 11,4
select * from t1 where i=12;     # 12,4
commit;

select * from t1;     # 1,19 | 2,16 | 3,1 | 11,4 | 12,4

####### read uncommitted #######

set session transaction isolation level read uncommitted;
select @@tx_isolation;

--error 203
select * from t1;

set session transaction isolation level read committed;
drop table t1;
