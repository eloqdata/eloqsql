--source include/have_eloq.inc

--disable_warnings
DROP DATABASE IF EXISTS db1;
--enable_warnings
--enable_info
set @@default_storage_engine= eloq;

CREATE DATABASE IF NOT EXISTS db1;

CREATE TABLE db1.t1 (a INT primary key);
SHOW CREATE TABLE db1.t1;
DROP TABLE db1.t1;

ALTER DATABASE db1 DEFAULT CHARACTER SET = utf8mb4;
ALTER DATABASE db1 DEFAULT COLLATE = utf8mb4_bin;

CREATE TABLE db1.t1 (a INT primary key);
SHOW CREATE TABLE db1.t1;
DROP TABLE db1.t1;

DROP DATABASE IF EXISTS db1;

--disable_info
