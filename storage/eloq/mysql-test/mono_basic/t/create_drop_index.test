--replace_column 9 #
explain select a1,a2,b,c,min(c), max(c) from t18
where exists ( select * from t19
               where t19.c in (select c from t20 where t20.c > t18.b) and
               t19.c > 'b1' )
group by a1,a2,b;

select a1,a2,b,c,min(c), max(c) from t18
where exists ( select * from t19
               where t19.c in (select c from t20 where t20.c > t18.b) and
               t19.c > 'b1' )
group by a1,a2,b;

--replace_column 9 #
explain select a1,a2,b,c,min(c), max(c) from t18
where exists ( select * from t19
               where t19.c in (select c from t20 where t20.c > t18.c) and
               t19.c > 'b1' )
group by a1,a2,b;

select a1,a2,b,c,min(c), max(c) from t18
where exists ( select * from t19
               where t19.c in (select c from t20 where t20.c > t18.c) and
               t19.c > 'b1' )
group by a1,a2,b;

#restore defaults
set optimizer_switch=default;
drop table t11,t12,t13,t14,t15,t16,t17,t18,t19,t20;
--echo # End of subselect exists2in tests

#
# From subselect_mat_cost_bugs.test
#
--echo #
--echo # MWL#89: test introduced after Sergey Petrunia's review - test that
--echo # keyparts wihtout index prefix are used with the IN-EXISTS strategy.
--echo #

create table t21 (c1 int);
insert into t21 values (1), (2), (3);

create table t22 (kp1 int, kp2 int, c2 int, filler char(100));
insert into t22 values (0,0,0,'filler'),(0,1,1,'filler'),(0,2,2,'filler'),(0,3,3,'filler');

create index key1 on t22 (kp1, kp2);
create index key2 on t22 (kp1);
create index key3 on t22 (kp2);

-- disable_query_log
-- disable_result_log
analyze table t22;
-- enable_result_log
-- enable_query_log

SET @@optimizer_switch='materialization=off,semijoin=off,in_to_exists=on';

--replace_column 9 #
explain
select c1 from t21 where c1 in (select kp1 from t22 where kp2 = 10 and c2 = 4) or c1 > 7;
select c1 from t21 where c1 in (select kp1 from t22 where kp2 = 10 and c2 = 4) or c1 > 7;

set @@optimizer_switch='default';

--echo # End of subselect mat cost bugs tests

#
# DuplicateElimination strategy test (from subselect_sj2.test)
#
set @subselect_sj2_tmp= @@optimizer_switch;
set optimizer_switch='semijoin=on,firstmatch=on,loosescan=on';
set optimizer_switch='mrr=on,mrr_sort_keys=on,index_condition_pushdown=on';
SET optimizer_switch=ifnull(@optimizer_switch_for_subselect_sj2_test,'outer_join_with_cache=off');
SET optimizer_switch=ifnull(@optimizer_switch_for_subselect_sj2_test,'semijoin_with_cache=off');
if (`select @join_cache_level_for_subselect_sj2_test is null`)
{
  set join_cache_level=1;
}
if (`select @join_cache_level_for_subselect_sj2_test is not null`)
{
  set join_cache_level=@join_cache_level_for_subselect_sj2_test;
}

#
# BUG#33743 "nested subqueries, unique index, wrong result"
#
CREATE TABLE t23
 (EMPNUM   CHAR(3) NOT NULL,
  EMPNAME  CHAR(20),
  GRADE    DECIMAL(4),
  CITY     CHAR(15));

CREATE TABLE t24
 (PNUM     CHAR(3) NOT NULL,
  PNAME    CHAR(20),
  PTYPE    CHAR(6),
  BUDGET   DECIMAL(9),
  CITY     CHAR(15));

CREATE TABLE t25
 (EMPNUM   CHAR(3) NOT NULL,
  PNUM     CHAR(3) NOT NULL,
  HOURS    DECIMAL(5));

