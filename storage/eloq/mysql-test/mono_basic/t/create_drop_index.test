SELECT t12.*, t14.DOCTYPENAME, t11.CONTENTSIZE,t11.MIMETYPE FROM t12 INNER JOIN t14 ON t12.DOCTYPEID = t14.DOCTYPEID LEFT OUTER JOIN t11 ON t12.DOCID = t11.DOCID WHERE t12.FOLDERID IN(SELECT t13.FOLDERID FROM t13 WHERE t13.PARENTID IN(SELECT t13.FOLDERID FROM t13 WHERE t13.PARENTID IN(SELECT t13.FOLDERID FROM t13 WHERE t13.PARENTID IN(SELECT t13.FOLDERID FROM t13 WHERE t13.PARENTID IN(SELECT t13.FOLDERID FROM t13 WHERE t13.PARENTID='2f6161e879db43c1a5b82c21ddc49089' AND t13.FOLDERNAME = 'Level1') AND t13.FOLDERNAME = 'Level2') AND t13.FOLDERNAME = 'Level3') AND t13.FOLDERNAME = 'CopiedFolder') AND t13.FOLDERNAME = 'Movie Reviews') AND t12.DOCNAME = 'Last Discussion';

--echo #
--echo # MDEV-4420: non-expensive single-value subquery used as
--echo #            used as an access key to join a table
--echo #

create table t15 (a varchar(3));
insert into t15 values ('USA'), ('FRA');
create table t16 select * from t15;
insert into t16 values ('RUS');
create table t17 select * from t16;
create index idx on t17(a);

#FIXME: explain extended
#select * from t15, t16 left join t17 on ( t16.a = t17.a )
#where t15.a = t16.a and ( t15.a = ( select min(a) from t15 ) or 0 );

select * from t15, t16 left join t17 on ( t16.a = t17.a )
where t15.a = t16.a and ( t15.a = ( select min(a) from t15 ) or 0 );

--echo # End of subselect2 tests

