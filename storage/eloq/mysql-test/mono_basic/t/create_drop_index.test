#
# test of updating of keys (from update.test)
#
#
# Bug #11868 Update with subquery with ref built with a key from the updated
#            table crashes server
#
create table t36(f1 int, f2 int);
create table t37(f3 int, f4 int);
create index idx on t37(f3);
insert into t36 values(1,0),(2,0);
insert into t37 values(1,1),(2,2);
UPDATE t36 SET t36.f2=(SELECT MAX(t37.f4) FROM t37 WHERE t37.f3=t36.f1);
select * from t36;

--echo # End of update tests

#
# From update_use_source.test
#
--source include/have_sequence.inc
USE test;
create table t38 (old_c1 integer, old_c2 integer,c1 integer, c2 integer, c3 integer) engine=eloq STATS_PERSISTENT=0;
create view v1 as select * from t38 where c2=2;
delimiter /;
create trigger trg_t38 before update on t38 for each row
begin
  set new.old_c1=old.c1;
  set new.old_c2=old.c2;
end;
/
delimiter ;/

insert into t38(c1,c2,c3) values (1,1,1);
insert into t38(c1,c2,c3) values (1,2,2);
insert into t38(c1,c2,c3) values (1,3,3);
insert into t38(c1,c2,c3) values (2,1,4);
insert into t38(c1,c2,c3) values (2,2,5);
insert into t38(c1,c2,c3) values (2,3,6);
insert into t38(c1,c2,c3) values (2,4,7);
insert into t38(c1,c2,c3) values (2,5,8);

commit;
select * from t38;

--echo Test with an index on updated columns
create index t38_c2 on t38 (c2,c1);
--source include/update_use_source_eloq.inc

--echo Test with an index on updated columns
create index t38_c3 on t38 (c3);
--source include/update_use_source_eloq.inc

drop index t38_c3 on t38;

USE mono_test;
--echo #
--echo # Test with Eloq
--echo #
create table t39 (old_c1 integer, old_c2 integer,c1 integer, c2 integer, c3 integer) engine=eloq;
insert t39 (c1,c2,c3) select 0,seq,seq%10 from seq_1_to_500;
insert t39 (c1,c2,c3) select 1,seq,seq%10 from seq_1_to_400;
insert t39 (c1,c2,c3) select 2,seq,seq%10 from seq_1_to_300;
insert t39 (c1,c2,c3) select 3,seq,seq%10 from seq_1_to_200;
create index t39_idx1 on t39(c3);

update t39 set c1=2 where exists (select 'x' from t39);
select count(*) from t39 where c1=2;
update t39 set c1=3 where c3 in (select c3 from t39 b where t39.c3=b.c1);
select count(*) from t39 where c1=3;

drop table t31,t32,t33,t34,t35,t36,t37,t39;
--echo # End of update use source tests

#
# From view.test
#
--source include/default_optimizer_switch.inc

SET optimizer_switch='outer_join_with_cache=off';
#
# using VIEW where table is required
#
create table t40 (col1 int,col2 char(22));
create view v2 as select * from t40;
-- error ER_WRONG_OBJECT
create index i1 on v2 (col1);

# Bug#12941
#
create table t41 (
  r_object_id char(16) NOT NULL,
  group_name varchar(32) NOT NULL
);

create table t42 (
  r_object_id char(16) NOT NULL,
  i_position int(11) NOT NULL,
  users_names varchar(32) default NULL
);

create view v3 as select r_object_id, group_name from t41;
create view v4 as select r_object_id, i_position, users_names from t42;

create index group_name on t41(group_name);
create index users_names on t42(users_names);

insert into t41 values('120001a080000542','tstgroup1');
insert into t42 values('120001a080000542',-1, 'guser01');
insert into t42 values('120001a080000542',-2, 'guser02');

select v3.r_object_id, v4.users_names from v3, v4
where (v3.group_name='tstgroup1') and v4.r_object_id=v3.r_object_id
order by users_names;

SET optimizer_switch='default';
--echo # End of view tests

#
#  Window Functions Tests (from win.test)
#

--echo #
--echo # MDEV-11990: window function over min/max aggregation
--echo #

create table t43 (id int);
insert into t43 values (1), (2), (3), (2), (4), (2);

select sum(max(id)) over (order by max(id)) from t43;
--replace_column 9 #
explain
select sum(max(id)) over (order by max(id)) from t43;

create index idx on t43(id);
select sum(max(id)) over (order by max(id)) from t43;
explain
select sum(max(id)) over (order by max(id)) from t43;
select sum(max(id)) over (order by max(id)) from t43 where id < 3;
select count(max(id)) over (order by max(id)) from t43 where id < 3;
select max(id), rank() over (order by max(id)) from t43 where id < 3;

--echo # End of view tests
# Clean up
drop view test.v1;
drop table test.t38;
drop view v2,v3,v4;
