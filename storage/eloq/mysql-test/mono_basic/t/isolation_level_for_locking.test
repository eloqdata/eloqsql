#eval kill query $connection_id;
#commit;  
# Here will be blocked for tx2 also acquired readlock and tx1 fail to acquire writelock.
# That is, deadlock.
#select * from t1 where i=1;    # 1,18

#--connection conn-tx2
#--reap

####### read committed #######
--connection conn-tx1
set session transaction isolation level read committed;
select @@tx_isolation;
--connection conn-tx2
set session transaction isolation level read committed;
select @@tx_isolation;

## rw-1
## tx1 : [b-r(i=1) -            - r(i=1)-c ]
## tx2 : [         - b-w(i=1)-c -          ]
echo "### RC test: rw-1 ###";
--connection conn-tx1
insert into t1 values(11,1);
select * from t1 where i=11;     # 11,1

Begin;
select * from t1 where i=11;     # 11,1

--connection conn-tx2
update t1 set j=2 where i=11;
select * from t1 where i=11;     # 11,2

--connection conn-tx1
select * from t1 where i=11;     # 11,2
commit;

select * from t1;     # 1,11 | 2,3 | 11,2

## rw-2
## tx1 : [b-r(i=1) -          - r(i=1) -   - r(i=1)- c ]
## tx2 : [         - b-w(i=1) -        - c -           ]
echo "### RC test: rw-2 ###";
--connection conn-tx1
begin;
select * from t1 where i=11;     # 11,2

--connection conn-tx2
begin;
update t1 set j=3 where i=11;
select * from t1 where i=11;     # 11,3

--connection conn-tx1
select * from t1 where i=11;     # 11,2

--connection conn-tx2
commit;

--connection conn-tx1
--echo "# result must be: 11,3"
select * from t1 where i=11;     # 11,3
commit;

select * from t1;     # 1,11 | 2,3 | 11,3


## rw-3
## tx1 : [b-r(i=1)-r(i=2) -            - r(i=1)-r(i=2)- c ]
## tx2 : [         - b-w(i=1)-w(i=2)-c -                  ]
echo "### RC test: rw-3 ###";
--connection conn-tx1
insert into t1 values(12,1);
begin;
select * from t1 where i=11;     # 11,3
select * from t1 where i=12;     # 12,1

--connection conn-tx2
begin;
update t1 set j=4 where i=11;
update t1 set j=4 where i=12;
commit;
select * from t1 where i=11;     # 11,4
select * from t1 where i=12;     # 12,4

--connection conn-tx1
select * from t1 where i=11;     # 11,4
select * from t1 where i=12;     # 12,4
commit;

select * from t1;     # 1,11 | 2,3 | 11,4 | 12,4

####### read uncommitted #######
echo "### RU test ###";
set session transaction isolation level read uncommitted;
select @@tx_isolation;

--error 203
select * from t1;

set session transaction isolation level read committed;
drop table t1;
