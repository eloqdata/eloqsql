--source include/have_eloq.inc

--disable_warnings
DROP DATABASE IF EXISTS db1;
--enable_warnings
--enable_info
set @@default_storage_engine= eloq;

--disable_warnings
DROP TABLE IF EXISTS t1;
--enable_warnings

# unsupported collation on text fields
--error ER_INTERNAL_ERROR
CREATE TABLE t1 (c1 VARCHAR(10) PRIMARY KEY) COLLATE cp852_general_nopad_ci;

--disable_warnings
DROP TABLE IF EXISTS t1;
--enable_warnings

--error ER_INTERNAL_ERROR
CREATE TABLE t1 (c1 TEXT, PRIMARY KEY(c1(10))) COLLATE cp852_general_nopad_ci;

# Secondary index should be checked as well
--error ER_INTERNAL_ERROR
CREATE TABLE t1 (c1 VARCHAR(10) COLLATE latin1_bin PRIMARY KEY,
                 c2 VARCHAR(10) COLLATE cp852_general_nopad_ci,
                 INDEX(c2));

--disable_warnings
DROP TABLE IF EXISTS t1;

DROP TABLE IF EXISTS t2;
--enable_warnings

# only supported collation should create successfully
CREATE TABLE t2 (c1 VARCHAR(10) PRIMARY KEY) COLLATE latin1_general_ci;

--disable_warnings
DROP TABLE IF EXISTS t2;

DROP TABLE IF EXISTS t3;
--enable_warnings

# colaltion on non-text fields should not matter
CREATE TABLE t3 (c1 int PRIMARY KEY COLLATE cp852_general_nopad_ci, c2 VARCHAR(10));

--disable_warnings
DROP TABLE IF EXISTS t3;

DROP TABLE IF EXISTS t4;
--enable_warnings

# JSON format should pass the index collation check since it uses utf8mb4
CREATE TABLE t4 (c1 JSON, PRIMARY KEY(c1(10)));

--disable_warnings
DROP TABLE IF EXISTS t4;
--enable_warnings
