--disable_warnings
call mtr.add_suppression("mariadbd: Table 't3' is marked as crashed and should be repaired");
call mtr.add_suppression("mariadbd: Table 't2' is marked as crashed and should be repaired");
DROP TABLE IF EXISTS t1;
DROP TABLE IF EXISTS t2;
DROP TABLE IF EXISTS t3;
--enable_warnings

create table t1(i int primary key, j int) engine=eloq;
insert into t1 values(1,1);
insert into t1 values(2,1);
insert into t1 values(3,1);

create table t2(i int primary key, j int) engine=eloq;
insert into t2 values(1,1);
insert into t2 values(2,1);
insert into t2 values(3,1);

select * from t1;
select * from t2;
--connect (con_1,localhost,root,,test,$MONO1_PORT)
begin;
update t1 set j=2 where i=1;
update t2 set j=2 where i=2;
update t1 set j=2 where i=3;

--connection default
begin;
update t2 set j=2 where i=1;
update t1 set j=2 where i=2;
update t2 set j=2 where i=3;

send update t1 set j=3 where i=1;

--connection con_1
send update t2 set j=3 where i=1;

# rely on timeout mechanism to detect deadlock
--connection con_1
--error HA_ERR_LOCK_DEADLOCK
reap;
select * from t1;
select * from t2;
commit;

--connection default
reap;
select * from t1;
select * from t2;
commit;

select * from t1;
select * from t2;

drop table t1;
drop table t2;


create table t3(i int primary key, j int) engine=eloq;
insert into t3 values(1,1);
insert into t3 values(2,1);
insert into t3 values(3,1);

--connect (con1,localhost,root,,test,$MONO1_PORT)
begin;
update t3 set j=2 where i=1;

--connect (con2,localhost,root,,test,$MONO1_PORT)
begin;
update t3 set j=2 where i=2;

--connect (con3,localhost,root,,test,$MONO1_PORT)
begin;
update t3 set j=2 where i=3;

--connection con1
send update t3 set j=3 where i=3;

--connection con2
send update t3 set j=3 where i=1;

--connection con3
send update t3 set j=3 where i=2;

# rely on timeout mechanism to detect deadlock
--connection con1
--error HA_ERR_LOCK_DEADLOCK
reap;
commit;

--connection con2
reap;
commit;

--connection con3
reap;
commit;

--connection default
select * from t3;
drop table t3;


create table t1(i int primary key, j int) engine=eloq;
insert into t1 values(1,1);
insert into t1 values(2,1);
insert into t1 values(3,1);


--connection con1
begin;
update t1 set j=2 where i=1;

--connection con2
begin;
update t1 set j=2 where i=2;

--connection con3
begin;
update t1 set j=2 where i=3;

--connection con2
send update t1 set j=3 where i=1;

--connection default
SET SESSION debug_dbug="+d,eloq;trigger_dead_lock_detection;node_id=0";
--sleep 5

--connection con1
commit;

--connection con2
reap;
commit;

--connection con3
commit;

--connection default
select * from t1;
drop table t1;

