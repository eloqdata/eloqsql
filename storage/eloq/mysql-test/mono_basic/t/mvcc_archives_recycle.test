--source include/have_eloq.inc

set @@default_storage_engine= eloq;
select @@default_storage_engine;

--disable_warnings
DROP TABLE IF EXISTS t1;
--enable_warnings

create table t1(i int primary key, j int) engine= eloq;

insert into t1 values(1,100);
insert into t1 values(2,100);
insert into t1 values(3,100);

select * from t1;      # 1,100 | 2,100 | 3,100

SET SESSION debug_dbug="+d,eloq;stop_safely_clean_archives;";
update t1 set j=1;
update t1 set j=2;
update t1 set j=3;
select * from t1;      # 1,3 | 2,3 | 3,3

#### test clean key: i=1
--connect (conn-tx1,localhost,root,,test,$MONO1_PORT)
begin;
select * from t1 where i=1;  # 1,3

--connection default
update t1 set j=11 where i=1;
update t1 set j=12 where i=1;
select * from t1 where i=1;  # 1,12

# run test:  flush archives, clean archives, check archives in store, check read return VersionUnkonwn 
SET SESSION debug_dbug="+d,eloq_test;archives_clean_test;./test/t1;1;";
select * from t1 where i=1;  #  1,12

--connection conn-tx1
select * from t1 where i=1;        # 1,3
select * from t1 where i=2;        # 2,3
commit;

# test key not in table
--error 206
SET SESSION debug_dbug="+d,eloq_test;archives_clean_test;./test/t1;5;";

select * from t1;   # 1,12 | 2,3 | 3,3

#### test clean key: i=3
# conn-tx1
begin;
select * from t1 where i=3;  # 3,3

--connection default
update t1 set j=31 where i=3;
update t1 set j=32 where i=3;
select * from t1 where i=3;   # 3,32

# run test:  flush archives, clean archives, check archives in store, check read return VersionUnkonwn 
SET SESSION debug_dbug="+d,eloq_test;archives_clean_test;./test/t1;3;";
select * from t1 where i=3;  #  3,32

--connection conn-tx1
select * from t1 where i=3;        # 3,3
select * from t1 where i=2;        # 2,3
commit;

# test key not in table
--error 206
SET SESSION debug_dbug="+d,eloq_test;archives_clean_test;./test/t1;5;";

select * from t1;   # 1,12 | 2,3 | 3,32

SET SESSION debug_dbug="-d,eloq;stop_safely_clean_archives;";
drop table t1;