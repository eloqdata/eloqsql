DROP TABLE IF EXISTS t1;
DROP TABLE IF EXISTS t2;
DROP TABLE IF EXISTS t3;
CREATE TABLE t1 (pk int primary key, c char(1)) ENGINE=eloq;
INSERT INTO t1 VALUES (1,'a'),(2,'b');
UPDATE t1 SET c = 'x' ORDER BY pk LIMIT 1;
SELECT * FROM t1;
pk	c
1	x
2	b
DROP TABLE t1;
CREATE TABLE t2 (a int primary key) ENGINE=eloq;
INSERT INTO t2 VALUES (1),(2);
CREATE TABLE t3 (b int primary key) ENGINE=eloq;
INSERT INTO t3 SELECT * FROM t2;
DELETE IGNORE t2.*, t3.* FROM t2, t3 WHERE b < a;
SELECT * FROM t2;
a
1
SELECT * FROM t3;
b
2
DROP TABLE t2;
DROP TABLE t3;
