set @@default_storage_engine= eloq;
select @@default_storage_engine;
@@default_storage_engine
ELOQ
DROP TABLE IF EXISTS t1;
create table t1(i int primary key, j int) engine= eloq;
insert into t1 values(1,100);
insert into t1 values(2,100);
insert into t1 values(3,100);
select * from t1;
i	j
1	100
2	100
3	100
SET SESSION debug_dbug="+d,eloq;stop_safely_clean_archives;";
update t1 set j=1;
update t1 set j=2;
update t1 set j=3;
select * from t1;
i	j
1	3
2	3
3	3
connect  conn-tx1,localhost,root,,test,$MONO1_PORT;
begin;
select * from t1 where i=1;
i	j
1	3
connection default;
update t1 set j=11 where i=1;
update t1 set j=12 where i=1;
select * from t1 where i=1;
i	j
1	12
SET SESSION debug_dbug="+d,eloq_test;archives_clean_test;./test/t1;1;";
select * from t1 where i=1;
i	j
1	12
connection conn-tx1;
select * from t1 where i=1;
i	j
1	3
select * from t1 where i=2;
i	j
2	3
commit;
SET SESSION debug_dbug="+d,eloq_test;archives_clean_test;./test/t1;5;";
