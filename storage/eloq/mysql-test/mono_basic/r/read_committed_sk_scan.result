set @@default_storage_engine= eloq;
select @@default_storage_engine;
@@default_storage_engine
ELOQ
DROP TABLE IF EXISTS t1;
CREATE TABLE t1 (pk INT , sk1 INT, sk2 INT,PRIMARY KEY (pk), INDEX sk1 (sk1), INDEX sk2 (sk2)) ENGINE=eloq;
INSERT INTO t1 VALUES (1, 1, 1),(2, 2, 2),(3, 3, 3);
set session transaction isolation level read committed;
select @@tx_isolation;
@@tx_isolation
READ-COMMITTED
select * from t1 where sk1>=2;
pk	sk1	sk2
2	2	2
3	3	3
DELETE FROM t1;
select * from t1;
pk	sk1	sk2
drop table t1;
