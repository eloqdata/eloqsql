set @@default_storage_engine= eloq;
select @@default_storage_engine;
@@default_storage_engine
ELOQ
DROP TABLE IF EXISTS t1,t2;
CREATE TABLE t1(
c1 int, 
c2 int, 
PRIMARY KEY(c1)
);
insert into t1 values(1,1);
insert into t1 values(3,3);
insert into t1 values(5,5);
insert into t1 values(7,7);
insert into t1 values(9,9);
CREATE TABLE t2(
c1 int, 
c2 int, 
PRIMARY KEY(c1)
);
insert into t2 values(2,2);
insert into t2 values(4,4);
insert into t2 values(6,6);
insert into t2 values(8,8);
connect  conn-tx1,localhost,root,,test,$MONO1_PORT;
connect  conn-tx2,localhost,root,,test,$MONO1_PORT;
connection conn-tx1;
SET TRANSACTION ISOLATION LEVEL REPEATABLE READ;
START TRANSACTION READ ONLY;
begin;
select count(*) from t1;
count(*)
5
connection conn-tx2;
begin;
delete from t2 where c1=2;
update t1 set c2=3 where c1=1;
commit;
connection conn-tx1;
select count(*) from t2;
connection conn-tx2;
ERROR HY000: Eloq: failed to commit transaction. try restarting transaction. Abort the transaction due to dead lock.
connection conn-tx1;
count(*)
4
commit;
drop table t1,t2;
