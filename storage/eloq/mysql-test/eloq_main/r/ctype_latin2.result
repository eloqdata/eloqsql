  `a` varchar(1) CHARACTER SET latin2 COLLATE latin2_bin NOT NULL
) ENGINE=ELOQ DEFAULT CHARSET=latin1
CREATE TABLE t2 AS SELECT WEIGHT_STRING(a) AS ws FROM t1;
