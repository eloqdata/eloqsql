# Bug#46616: Assertion `!table->auto_increment_field_not_null' on view   
# manipulations
#
CREATE TABLE t1 ( a INT );
INSERT INTO t1 VALUES (1), (1);
CREATE TABLE t2 ( a INT AUTO_INCREMENT KEY );
INSERT INTO t2 SELECT a FROM t1;
SELECT a FROM t2;
a
1
2
DROP TABLE t1, t2;
