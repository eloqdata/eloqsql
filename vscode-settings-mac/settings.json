{
    "C_Cpp.autocompleteAddParentheses": true,
    "C_Cpp.default.configurationProvider": "ms-vscode.cmake-tools",
    "C_Cpp.default.cppStandard": "c++17",
    "C_Cpp.default.intelliSenseMode": "macos-clang-x64",
    "C_Cpp.files.exclude": {
        "**/.vscode": true,
        "**/BUILD": true,
        "**/install": true
    },
    "C_Cpp.intelliSenseCacheSize": 5120,
    "C_Cpp.intelliSenseMemoryLimit": 4096,
    "cmake.buildDirectory": "${workspaceFolder}/build/${buildKit}/${buildType}",
    "cmake.configureOnOpen": false,
    "cmake.configureSettings": {
        "BRPC_WITH_GLOG": "OFF",
        "CMAKE_CXX_FLAGS_DEBUG": "-O0 -g -Wno-error",
        "CMAKE_CXX_FLAGS_RELWITHDEBINFO": "-O2 -g -DNDEBUG -Wno-error",
        "CMAKE_CXX_FLAGS_RELEASE": "-O3 -g -DNDEBUG",
        "CONC_WITH_UNITTEST": false,
        "INSTALL_MYSQLTESTDIR": "",
        "MYSQL_MAINTAINER_MODE": "OFF",
        "OPENSSL_ROOT_DIR": "/usr/local/opt/openssl@1.1",
        "PLUGIN_ARCHIVE": "NO",
        "PLUGIN_ARIA": "NO",
        "PLUGIN_CONNECT": "NO",
        "PLUGIN_CVS": "NO",
        "PLUGIN_FEDERATED": "NO",
        "PLUGIN_FEDERATEDX": "NO",
        "PLUGIN_HANDLERSOCKET": "NO",
        "PLUGIN_HEAP": "NO",
        "PLUGIN_MROONGA": "NO",
        "PLUGIN_MYISAM": "NO",
        "PLUGIN_MYISAMMRG": "NO",
        "PLUGIN_OQGRAPH": "NO",
        "PLUGIN_PERFSCHEMA": "NO",
        "PLUGIN_ROCKSDB": "NO",
        "PLUGIN_SEQUENCE": "NO",
        "PLUGIN_SPHINX": "NO",
        "PLUGIN_SPIDER": "NO",
        "PLUGIN_TOKUDB": "NO",
        "WITH_EMBEDDED_SERVER": false,
        "WITH_SAFEMALLOC": false,
        "WITH_SSL": "system",
        "WITH_UNIT_TESTS": false,
        "WITH_WSREP": true
    },
    "cmake.installPrefix": "/path/to/installer/${buildKit}/${buildType}",
    "cmake.parallelJobs": 8,
    "cmake.preferredGenerators": [
        "Ninja"
    ],
    "editor.quickSuggestions": {
        "comments": false,
        "other": true,
        "strings": false
    },
    "files.associations": {
        "*.ic": "cpp",
        "*.inc": "cpp",
        "*.ipp": "cpp",
        "*.tcc": "cpp",
        "__bit_reference": "cpp",
        "__functional_03": "cpp",
        "__functional_base_03": "cpp",
        "__hash_table": "cpp",
        "__locale": "cpp",
        "__node_handle": "cpp",
        "__split_buffer": "cpp",
        "__string": "cpp",
        "__threading_support": "cpp",
        "__tree": "cpp",
        "algorithm": "cpp",
        "array": "cpp",
        "atomic": "cpp",
        "bitset": "cpp",
        "cctype": "cpp",
        "cfenv": "cpp",
        "chrono": "cpp",
        "cinttypes": "cpp",
        "clocale": "cpp",
        "cmath": "cpp",
        "codecvt": "cpp",
        "complex": "cpp",
        "condition_variable": "cpp",
        "csignal": "cpp",
        "cstdarg": "cpp",
        "cstddef": "cpp",
        "cstdint": "cpp",
        "cstdio": "cpp",
        "cstdlib": "cpp",
        "cstring": "cpp",
        "ctime": "cpp",
        "cwchar": "cpp",
        "cwctype": "cpp",
        "dense_hash_map": "cpp",
        "dense_hash_set": "cpp",
        "deque": "cpp",
        "exception": "cpp",
        "filesystem": "cpp",
        "forward_list": "cpp",
        "fstream": "cpp",
        "functional": "cpp",
        "future": "cpp",
        "hash_map": "cpp",
        "hash_set": "cpp",
        "initializer_list": "cpp",
        "iomanip": "cpp",
        "iosfwd": "cpp",
        "iostream": "cpp",
        "istream": "cpp",
        "iterator": "cpp",
        "limits": "cpp",
        "list": "cpp",
        "locale": "cpp",
        "map": "cpp",
        "memory": "cpp",
        "memory_resource": "cpp",
        "mutex": "cpp",
        "new": "cpp",
        "numeric": "cpp",
        "optional": "cpp",
        "ostream": "cpp",
        "queue": "cpp",
        "random": "cpp",
        "ratio": "cpp",
        "regex": "cpp",
        "set": "cpp",
        "shared_mutex": "cpp",
        "sstream": "cpp",
        "stack": "cpp",
        "stdexcept": "cpp",
        "streambuf": "cpp",
        "string": "cpp",
        "string_view": "cpp",
        "strstream": "cpp",
        "system_error": "cpp",
        "thread": "cpp",
        "tuple": "cpp",
        "type_traits": "cpp",
        "typeindex": "cpp",
        "typeinfo": "cpp",
        "unordered_map": "cpp",
        "unordered_set": "cpp",
        "utility": "cpp",
        "valarray": "cpp",
        "variant": "cpp",
        "vector": "cpp"
    },
    "files.exclude": {
        "folder_with_generated_files": true
    },
    "git.detectSubmodules": false,
    "lldb.dereferencePointers": true,
    "lldb.displayFormat": "auto",
    "lldb.showDisassembly": "never",
    "search.followSymlinks": false,
    "todo-tree.tree.scanMode": "workspace"
}