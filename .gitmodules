	path = wsrep-lib
	url = https://github.com/codership/wsrep-lib.git
	branch = master
[submodule "extra/wolfssl/wolfssl"]
	path = extra/wolfssl/wolfssl
	url = https://github.com/wolfSSL/wolfssl.git
[submodule "storage/maria/libmarias3"]
